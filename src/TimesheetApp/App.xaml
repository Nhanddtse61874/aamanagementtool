<Application x:Class="TimesheetApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:TimesheetApp.Views.Converters">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Views/Theme/Theme.xaml"/>
      </ResourceDictionary.MergedDictionaries>
      <conv:OverEightTagConverter x:Key="OverEightTag"/>
      <conv:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>
      <conv:BoolToVisibilityConverter x:Key="BoolToVisibleConverter"/>
      <conv:ActiveStatusConverter x:Key="ActiveStatusConverter"/>
      <conv:StringMatchConverter x:Key="StringMatch"/>
      <conv:StringMatchToVisibilityConverter x:Key="StringMatchToVisibility"/>
      <conv:InitialConverter x:Key="Initial"/>
      <conv:DateOnlyConverter x:Key="DateOnly"/>
    </ResourceDictionary>
  </Application.Resources>
</Application>
