<Window x:Class="TimesheetApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tabs="clr-namespace:TimesheetApp.Views.Tabs"
        Title="Timesheet Tool"
        Width="1100" Height="720"
        Background="{StaticResource WindowBg}"
        WindowStartupLocation="CenterScreen">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Header bar: app title (left) + current-user chip (right, XC-07) -->
    <Border Grid.Row="0" Background="{StaticResource Surface}"
            BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="20,12">
      <Grid>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Border Background="{StaticResource Accent}" CornerRadius="7" Width="30" Height="30"
                  Margin="0,0,10,0">
            <TextBlock Text="T" Foreground="White" FontWeight="Bold" FontSize="16"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <TextBlock Text="Timesheet Tool" FontSize="18" FontWeight="SemiBold"
                     VerticalAlignment="Center"/>
        </StackPanel>

        <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                Background="{StaticResource AccentSoft}" CornerRadius="14" Padding="12,5">
          <TextBlock VerticalAlignment="Center" Foreground="{StaticResource Accent}" FontWeight="SemiBold">
            <Run Text="&#128100; "/>
            <Run Text="{Binding CurrentUserName, Mode=OneWay, TargetNullValue='(chưa chọn)', FallbackValue='(chưa chọn)'}"/>
          </TextBlock>
        </Border>
      </Grid>
    </Border>

    <!-- XC-08: conflict-copy startup banner, collapsed when the warning string is empty -->
    <Border Grid.Row="1"
            Background="#FEF3C7" BorderBrush="#FDE68A" BorderThickness="1" CornerRadius="8"
            Padding="12,8" Margin="20,12,20,0">
      <Border.Style>
        <Style TargetType="Border">
          <Setter Property="Visibility" Value="Visible"/>
          <Style.Triggers>
            <DataTrigger Binding="{Binding ConflictWarning}" Value="">
              <Setter Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <TextBlock Text="{Binding ConflictWarning, Mode=OneWay}"
                 TextWrapping="Wrap" Foreground="#92400E"/>
    </Border>

    <!-- Tab strip -->
    <TabControl Grid.Row="3" Margin="20,12,20,0" SelectionChanged="OnTabChanged">
      <TabItem Header="Timesheet">
        <tabs:TimesheetTab DataContext="{Binding Timesheet}"/>
      </TabItem>
      <TabItem Header="Requests">
        <tabs:RequestsTab DataContext="{Binding Requests}"/>
      </TabItem>
      <TabItem Header="Users">
        <tabs:UsersTab DataContext="{Binding Users}"/>
      </TabItem>
      <TabItem Header="Reports">
        <tabs:ReportsTab DataContext="{Binding Reports}"/>
      </TabItem>
      <TabItem Header="Settings">
        <tabs:SettingsTab DataContext="{Binding Settings}"/>
      </TabItem>
    </TabControl>
  </Grid>
</Window>
