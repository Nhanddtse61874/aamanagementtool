<Window x:Class="TimesheetApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tabs="clr-namespace:TimesheetApp.Views.Tabs"
        Title="Worklog"
        Width="1180" Height="760" MinWidth="980" MinHeight="620"
        Background="{StaticResource WindowBg}"
        WindowStartupLocation="CenterScreen">

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="218"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- ============================ SIDEBAR ============================ -->
    <Border Grid.Column="0" Background="{StaticResource SidebarBg}"
            BorderBrush="{StaticResource SidebarBorder}" BorderThickness="0,0,1,0">
      <DockPanel>

        <!-- Brand / logo -->
        <Border DockPanel.Dock="Top" BorderBrush="{StaticResource SidebarBorder}"
                BorderThickness="0,0,0,1" Padding="16,15">
          <StackPanel Orientation="Horizontal">
            <Border Background="{StaticResource Accent}" CornerRadius="8" Width="34" Height="34"
                    Margin="0,0,10,0">
              <TextBlock Text="W" Foreground="White" FontWeight="Bold" FontSize="16"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="Worklog" FontSize="14" FontWeight="Bold"/>
              <TextBlock Text="Desktop · WPF" FontSize="11" Foreground="{StaticResource SectionLabel}"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Current-user chip (bottom, XC-07) -->
        <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource SidebarBorder}"
                BorderThickness="0,1,0,0" Padding="12">
          <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource SidebarBorder}"
                  BorderThickness="1" CornerRadius="7" Padding="9,7">
            <StackPanel Orientation="Horizontal">
              <Border Background="{StaticResource Accent}" CornerRadius="13" Width="26" Height="26"
                      Margin="0,0,9,0">
                <TextBlock Text="{Binding CurrentUserInitial}" Foreground="White" FontWeight="Bold"
                           FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{Binding CurrentUserName, TargetNullValue='(none selected)', FallbackValue='(none selected)'}"
                           FontSize="12" FontWeight="SemiBold"/>
                <TextBlock Text="Active" FontSize="11" Foreground="{StaticResource SectionLabel}"/>
              </StackPanel>
              <Ellipse Width="7" Height="7" Fill="#22C55E" VerticalAlignment="Center"
                       Margin="10,0,0,0"/>
            </StackPanel>
          </Border>
        </Border>

        <!-- Navigation -->
        <StackPanel Margin="12,12,12,0">
          <TextBlock Style="{StaticResource SidebarSection}" Text="WORKSPACE"/>

          <RadioButton Style="{StaticResource NavItem}" Tag="&#128197;" Content="Timesheet"
                       IsChecked="{Binding ActiveView, Converter={StaticResource StringMatch},
                                   ConverterParameter=timesheet, Mode=TwoWay}"/>

          <RadioButton Style="{StaticResource NavItem}" Tag="&#128221;" Content="Daily Report"
                       IsChecked="{Binding ActiveView, Converter={StaticResource StringMatch},
                                   ConverterParameter=dailyreport, Mode=TwoWay}"/>

          <!-- Planned (SOON) — disabled, pill on the right -->
          <Grid>
            <RadioButton Style="{StaticResource NavItem}" Tag="&#9989;" Content="Task List"
                         IsEnabled="False"/>
            <Border Style="{StaticResource SoonPill}" HorizontalAlignment="Right" Margin="0,0,8,0"
                    IsHitTestVisible="False">
              <TextBlock Text="SOON" FontSize="9" FontWeight="Bold" Foreground="{StaticResource AmberFg}"/>
            </Border>
          </Grid>

          <TextBlock Style="{StaticResource SidebarSection}" Text="ADMIN"/>
          <RadioButton Style="{StaticResource NavItem}" Tag="&#128101;" Content="Users"
                       IsChecked="{Binding ActiveView, Converter={StaticResource StringMatch},
                                   ConverterParameter=users, Mode=TwoWay}"/>
          <RadioButton Style="{StaticResource NavItem}" Tag="&#9881;" Content="Settings"
                       IsChecked="{Binding ActiveView, Converter={StaticResource StringMatch},
                                   ConverterParameter=settings, Mode=TwoWay}"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- ============================ MAIN ============================ -->
    <Grid Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Startup / integrity banners -->
      <StackPanel Grid.Row="0">

        <!-- XC-08 conflict-copy banner -->
        <Border Background="#FEF3C7" BorderBrush="#FDE68A" BorderThickness="1"
                CornerRadius="8" Padding="12,8" Margin="22,14,22,0">
          <Border.Style>
            <Style TargetType="Border">
              <Setter Property="Visibility" Value="Visible"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding ConflictWarning}" Value="">
                  <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Border.Style>
          <TextBlock Text="{Binding ConflictWarning, Mode=OneWay}" TextWrapping="Wrap" Foreground="#92400E"/>
        </Border>

        <!-- XC-09 lingering-journal (data-integrity) banner with a dismiss button -->
        <Border Background="#FEE2E2" BorderBrush="#FECACA" BorderThickness="1"
                CornerRadius="8" Padding="12,8" Margin="22,14,22,0">
          <Border.Style>
            <Style TargetType="Border">
              <Setter Property="Visibility" Value="Visible"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding JournalWarning}" Value="">
                  <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Border.Style>
          <DockPanel>
            <Button DockPanel.Dock="Right" Content="Dismiss" Command="{Binding DismissJournalWarningCommand}"
                    Style="{StaticResource MiniGhostButton}" VerticalAlignment="Center" Margin="12,0,0,0"/>
            <TextBlock Text="{Binding JournalWarning, Mode=OneWay}" TextWrapping="Wrap"
                       Foreground="#991B1B" VerticalAlignment="Center"/>
          </DockPanel>
        </Border>
      </StackPanel>

      <!-- Content host: one panel per ActiveView, only the matching one visible -->
      <Grid Grid.Row="1">

        <!-- ===== TIMESHEET (Entry / Requests / Reports sub-tabs) ===== -->
        <DockPanel Visibility="{Binding ActiveView, Converter={StaticResource StringMatchToVisibility},
                                ConverterParameter=timesheet}">
          <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="22,16,22,0">
            <TextBlock Text="&#128197;" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
            <TextBlock Style="{StaticResource FeatureTitle}" Text="Timesheet"/>
            <TextBlock Text="Log hours per request &amp; task" Margin="10,0,0,0"
                       Foreground="{StaticResource SectionLabel}" FontSize="13" VerticalAlignment="Center"/>
          </StackPanel>
          <TabControl x:Name="SubTabs" Margin="22,8,22,0" SelectionChanged="OnSubTabChanged">
            <TabItem Header="Entry">
              <tabs:TimesheetTab DataContext="{Binding Timesheet}"/>
            </TabItem>
            <TabItem Header="Requests">
              <tabs:RequestsTab DataContext="{Binding Requests}"/>
            </TabItem>
            <TabItem Header="Reports">
              <tabs:ReportsTab DataContext="{Binding Reports}"/>
            </TabItem>
          </TabControl>
        </DockPanel>

        <!-- ===== DAILY REPORT (Input / Board sub-tabs) ===== -->
        <DockPanel Visibility="{Binding ActiveView, Converter={StaticResource StringMatchToVisibility},
                                ConverterParameter=dailyreport}"
                   DataContext="{Binding DailyReport}">
          <StackPanel DockPanel.Dock="Top" Margin="22,16,22,0">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#128221;" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
              <TextBlock Style="{StaticResource FeatureTitle}" Text="Daily Report"/>
              <TextBlock Text="Standup — what each member did yesterday &amp; is doing today" Margin="10,0,0,0"
                         Foreground="{StaticResource SectionLabel}" FontSize="13" VerticalAlignment="Center"/>
            </StackPanel>
            <!-- Shared date toolbar (drives both Input and Board sub-tabs) -->
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
              <Button Content="◀" Style="{StaticResource ToolbarGhostButton}" Command="{Binding PrevDayCommand}"/>
              <DatePicker Width="150" Margin="6,0" VerticalContentAlignment="Center"
                          SelectedDate="{Binding SelectedDate, Converter={StaticResource DateOnly}}"/>
              <Button Content="▶" Style="{StaticResource ToolbarGhostButton}" Command="{Binding NextDayCommand}"/>
              <Button Content="Archive week" Style="{StaticResource ToolbarGhostButton}" Margin="14,0,0,0"
                      Command="{Binding ArchiveWeekCommand}"/>
              <TextBlock Text="{Binding StatusMessage}" Margin="14,0,0,0" VerticalAlignment="Center"
                         Foreground="{StaticResource TextSecondary}" FontSize="12"/>
            </StackPanel>
          </StackPanel>
          <TabControl Margin="22,8,22,0">
            <TabItem Header="Input">
              <tabs:DailyInputTab/>
            </TabItem>
            <TabItem Header="Team board">
              <tabs:DailyBoardTab/>
            </TabItem>
          </TabControl>
        </DockPanel>

        <!-- ===== USERS ===== -->
        <DockPanel Visibility="{Binding ActiveView, Converter={StaticResource StringMatchToVisibility},
                                ConverterParameter=users}">
          <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="22,16,22,8">
            <TextBlock Text="&#128101;" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
            <TextBlock Style="{StaticResource FeatureTitle}" Text="Users"/>
            <TextBlock Text="Manage app accounts" Margin="10,0,0,0"
                       Foreground="{StaticResource SectionLabel}" FontSize="13" VerticalAlignment="Center"/>
          </StackPanel>
          <tabs:UsersTab DataContext="{Binding Users}" Margin="10,0,10,0"/>
        </DockPanel>

        <!-- ===== SETTINGS ===== -->
        <DockPanel Visibility="{Binding ActiveView, Converter={StaticResource StringMatchToVisibility},
                                ConverterParameter=settings}">
          <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="22,16,22,8">
            <TextBlock Text="&#9881;" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
            <TextBlock Style="{StaticResource FeatureTitle}" Text="Settings"/>
            <TextBlock Text="Database &amp; preferences" Margin="10,0,0,0"
                       Foreground="{StaticResource SectionLabel}" FontSize="13" VerticalAlignment="Center"/>
          </StackPanel>
          <tabs:SettingsTab DataContext="{Binding Settings}"/>
        </DockPanel>

      </Grid>
    </Grid>
  </Grid>
</Window>
