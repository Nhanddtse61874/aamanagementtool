<Window x:Class="TimesheetApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tabs="clr-namespace:TimesheetApp.Views.Tabs"
        Title="Timesheet Tool"
        Width="1100" Height="720"
        WindowStartupLocation="CenterScreen">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Top corner: current user (XC-07) -->
    <TextBlock Grid.Row="0"
               HorizontalAlignment="Right" Margin="12,8"
               FontWeight="SemiBold">
      <Run Text="Người dùng: "/>
      <Run Text="{Binding CurrentUserName, Mode=OneWay}"/>
    </TextBlock>

    <!-- XC-08: conflict-copy startup banner, collapsed when the warning string is empty -->
    <Border Grid.Row="1"
            Background="#FFF3CD" BorderBrush="#FFE69C" BorderThickness="1"
            Padding="8,6" Margin="12,0,12,8">
      <Border.Style>
        <Style TargetType="Border">
          <Setter Property="Visibility" Value="Visible"/>
          <Style.Triggers>
            <DataTrigger Binding="{Binding ConflictWarning}" Value="">
              <Setter Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <TextBlock Text="{Binding ConflictWarning, Mode=OneWay}"
                 TextWrapping="Wrap" Foreground="#664D03"/>
    </Border>

    <TabControl Grid.Row="2" Margin="8">
      <TabItem Header="Timesheet">
        <tabs:TimesheetTab DataContext="{Binding Timesheet}"/>
      </TabItem>
      <TabItem Header="Requests">
        <tabs:RequestsTab DataContext="{Binding Requests}"/>
      </TabItem>
      <TabItem Header="Users">
        <tabs:UsersTab DataContext="{Binding Users}"/>
      </TabItem>
      <TabItem Header="Reports">
        <tabs:ReportsTab DataContext="{Binding Reports}"/>
      </TabItem>
      <TabItem Header="Settings">
        <tabs:SettingsTab DataContext="{Binding Settings}"/>
      </TabItem>
    </TabControl>
  </Grid>
</Window>
