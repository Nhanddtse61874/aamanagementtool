<UserControl x:Class="TimesheetApp.Views.Controls.TagPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- P13 W2: multi-select tag dropdown. Mirrors TeamFilter: a ghost ToggleButton ("Tags (N) ▾")
         opening a Popup with an optional type-to-filter TextBox + checkable chip rows.
         ItemsSource = ObservableCollection<TagPickVm>; each item: bool IsChecked + Tag {Text,Icon,Color}. -->
    <StackPanel Orientation="Horizontal">
        <ToggleButton x:Name="TagsToggle" Style="{StaticResource ToolbarGhostToggle}"
                      Content="{Binding HeaderText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      Padding="10,4"/>
        <Popup x:Name="PickerPopup" IsOpen="{Binding IsChecked, ElementName=TagsToggle}" StaysOpen="False"
               PlacementTarget="{Binding ElementName=TagsToggle}" Placement="Bottom"
               AllowsTransparency="True" PopupAnimation="Fade">
            <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
                    BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,4,0,0" MinWidth="180">
                <Border.Effect>
                    <DropShadowEffect Color="#0F172A" Opacity="0.22" BlurRadius="16" ShadowDepth="2" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <!-- type-to-filter TextBox: filters displayed rows by Tag.Text -->
                    <TextBox x:Name="FilterBox"
                             TextChanged="FilterBox_TextChanged"
                             Margin="0,0,0,6"
                             ToolTip="Type to filter tags"/>
                    <ItemsControl x:Name="TagItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                          Margin="0,2" VerticalContentAlignment="Center">
                                    <Border CornerRadius="10" Padding="9,2" Margin="2,0,0,0"
                                            HorizontalAlignment="Left" VerticalAlignment="Center"
                                            Background="{Binding Tag.Color, Converter={StaticResource HexToBrush}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Tag.Icon}" Margin="0,0,5,0"
                                                       FontFamily="Segoe UI Emoji"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Tag.Text}" FontWeight="SemiBold"
                                                       Foreground="White" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </CheckBox>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Popup>
    </StackPanel>
</UserControl>
