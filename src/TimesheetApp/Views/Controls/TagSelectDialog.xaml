<Window x:Class="TimesheetApp.Views.Controls.TagSelectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit tags" Width="300" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">
  <Border Background="{DynamicResource Surface}" CornerRadius="12" BorderBrush="{DynamicResource Border}"
          BorderThickness="1" Margin="12">
    <Border.Effect>
      <DropShadowEffect Color="#0F172A" Opacity="0.3" BlurRadius="24" ShadowDepth="4" Direction="270"/>
    </Border.Effect>
    <DockPanel>
      <!-- Header -->
      <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBg}" CornerRadius="12,12,0,0"
              Padding="20,14" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
        <TextBlock Text="Chọn tag" FontWeight="Bold" FontSize="17" Foreground="{DynamicResource TextPrimary}"/>
      </Border>
      <!-- Footer -->
      <Border DockPanel.Dock="Bottom" Background="{DynamicResource HeaderBg}" CornerRadius="0,0,12,12"
              Padding="20,12" BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0">
        <Button Content="Xong" Padding="22,6" IsDefault="True" IsCancel="True"
                HorizontalAlignment="Right" Click="OnDone"/>
      </Border>
      <!-- Body: checkable tag rows. Toggling a checkbox mutates the same TagPickVm the row VM is subscribed
           to, so each toggle commits immediately; the chips refresh when this dialog closes. -->
      <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto">
        <ItemsControl x:Name="TagList" Margin="18,14">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" Margin="0,3" VerticalContentAlignment="Center">
                <Border CornerRadius="10" Padding="9,2" Margin="4,0,0,0" HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="{Binding Tag.Color, Converter={StaticResource HexToBrush}}">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Tag.Icon}" Margin="0,0,5,0" FontFamily="Segoe UI Emoji"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Tag.Text}" FontWeight="SemiBold" Foreground="White"
                               VerticalAlignment="Center"/>
                  </StackPanel>
                </Border>
              </CheckBox>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </DockPanel>
  </Border>
</Window>
