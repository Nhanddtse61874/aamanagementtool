<UserControl x:Class="TimesheetApp.Views.Controls.TeamFilter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- DataContext = TeamFilterViewModel. A "Teams ▾" dropdown checklist (TM-07). Hidden for
         single-team users via ShowFilter. Each checkbox toggle bubbles up SelectionChanged so the
         owner VM reloads its data with the new CheckedTeamIds. -->
    <StackPanel Orientation="Horizontal"
                Visibility="{Binding ShowFilter, Converter={StaticResource BoolToVisibleConverter}}">
        <TextBlock Text="Teams:" VerticalAlignment="Center" Margin="0,0,4,0"/>
        <ToggleButton x:Name="TeamsToggle" Style="{StaticResource ToolbarGhostToggle}"
                      Content="{Binding HeaderText}" Padding="10,4"/>
        <Popup IsOpen="{Binding IsChecked, ElementName=TeamsToggle}" StaysOpen="False"
               PlacementTarget="{Binding ElementName=TeamsToggle}" Placement="Bottom"
               AllowsTransparency="True" PopupAnimation="Fade">
            <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
                    BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,4,0,0" MinWidth="160">
                <Border.Effect>
                    <DropShadowEffect Color="#0F172A" Opacity="0.22" BlurRadius="16" ShadowDepth="2" Direction="270"/>
                </Border.Effect>
                <ItemsControl ItemsSource="{Binding Teams}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                      Margin="0,3" VerticalContentAlignment="Center"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </Popup>
    </StackPanel>
</UserControl>
