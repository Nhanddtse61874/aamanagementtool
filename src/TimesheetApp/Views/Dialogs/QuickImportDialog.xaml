<Window x:Class="TimesheetApp.Views.Dialogs.QuickImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick import" Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">
  <!-- Pick a past day; its full standup (the current user's entries + issues) is cloned into the current day. -->
  <Border Background="{DynamicResource Surface}" CornerRadius="12" BorderBrush="{DynamicResource Border}"
          BorderThickness="1" Margin="12">
    <Border.Effect>
      <DropShadowEffect Color="#0F172A" Opacity="0.3" BlurRadius="24" ShadowDepth="4" Direction="270"/>
    </Border.Effect>
    <DockPanel>
      <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBg}" CornerRadius="12,12,0,0"
              Padding="20,14" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
        <TextBlock Text="Quick import" FontWeight="Bold" FontSize="17" Foreground="{DynamicResource TextPrimary}"/>
      </Border>
      <Border DockPanel.Dock="Bottom" Background="{DynamicResource HeaderBg}" CornerRadius="0,0,12,12"
              Padding="20,12" BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Content="Cancel" Style="{StaticResource GhostButton}" Padding="18,6" Margin="0,0,8,0" IsCancel="True"/>
          <Button Content="Import" Padding="22,6" IsDefault="True" Click="OnImport"/>
        </StackPanel>
      </Border>
      <StackPanel Margin="20,16">
        <TextBlock Text="Copy a past day's items into the current day (you can edit them after)."
                   Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,10"/>
        <TextBlock Text="Source day" Style="{StaticResource FieldLabel}"/>
        <DatePicker x:Name="SourcePicker"/>
        <TextBlock x:Name="ErrorText" Foreground="{DynamicResource Danger}" FontSize="12" Margin="0,8,0,0"
                   TextWrapping="Wrap" Visibility="Collapsed"/>
      </StackPanel>
    </DockPanel>
  </Border>
</Window>
