<Window x:Class="TimesheetApp.Views.Dialogs.SelectUserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chọn người dùng"
        Width="360" Height="320"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               Text="Không nhận diện được tài khoản Windows. Chọn người dùng của bạn:"
               TextWrapping="Wrap" Margin="0,0,0,8"/>

    <ListBox Grid.Row="1"
             x:Name="UsersList"
             DisplayMemberPath="Name"
             SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
             MouseDoubleClick="UsersList_MouseDoubleClick"/>

    <StackPanel Grid.Row="2" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="0,8,0,0">
      <Button Content="OK" Width="80" Margin="0,0,8,0"
              IsDefault="True" Click="Ok_Click"/>
      <Button Content="Hủy" Width="80"
              IsCancel="True"/>
    </StackPanel>
  </Grid>
</Window>
