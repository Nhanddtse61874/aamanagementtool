<Window x:Class="TimesheetApp.Views.Dialogs.SelectUserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select user"
        Width="360" Height="380"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               Text="Windows account not recognized. Select your user:"
               TextWrapping="Wrap" Margin="0,0,0,8"/>

    <ListBox Grid.Row="1"
             x:Name="UsersList"
             DisplayMemberPath="Name"
             SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
             MouseDoubleClick="UsersList_MouseDoubleClick"/>

    <!-- First-run: the user list can be empty; let the user create themselves inline. -->
    <StackPanel Grid.Row="2" Margin="0,8,0,0">
      <TextBlock Text="Or create a new user (enter a name, then click OK):"
                 TextWrapping="Wrap" Margin="0,0,0,4"/>
      <TextBox x:Name="NewUserNameBox"/>
    </StackPanel>

    <StackPanel Grid.Row="3" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button Content="OK" Width="80" Margin="0,0,8,0"
              IsDefault="True" Click="Ok_Click"/>
      <Button Content="Cancel" Width="80"
              IsCancel="True"/>
    </StackPanel>
  </Grid>
</Window>
