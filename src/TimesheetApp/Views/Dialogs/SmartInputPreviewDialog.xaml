<Window x:Class="TimesheetApp.Views.Dialogs.SmartInputPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart fill" Width="480" Height="680" WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False" ResizeMode="NoResize" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent">
  <!-- DataContext is the TimesheetViewModel.SmartInput (SmartInputPanelVm). -->
  <Border Background="{StaticResource Surface}" CornerRadius="12" BorderBrush="{StaticResource Border}"
          BorderThickness="1" Margin="12">
    <Border.Effect>
      <DropShadowEffect Color="#0F172A" Opacity="0.3" BlurRadius="24" ShadowDepth="4" Direction="270"/>
    </Border.Effect>
    <DockPanel>
      <!-- Header -->
      <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBg}" CornerRadius="12,12,0,0"
              Padding="20,14" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
        <TextBlock Text="&#9889; Smart fill" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextPrimary}"/>
      </Border>

      <!-- Footer (sticky) -->
      <Border DockPanel.Dock="Bottom" Background="{StaticResource HeaderBg}" CornerRadius="0,0,12,12"
              Padding="20,12" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Content="Cancel" Style="{StaticResource GhostButton}" Padding="18,6" Margin="0,0,8,0" IsCancel="True"/>
          <Button Content="Confirm" Padding="22,6" IsDefault="True" Command="{Binding ApplyCommand}"/>
        </StackPanel>
      </Border>

      <!-- Body: inputs (auto) + preview (fills remaining, scrolls) -->
      <Grid Margin="20,16">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
          <!-- 1) Backlog (contains search) -> Find -->
          <TextBlock Text="Backlog (search by part of the code)" Style="{StaticResource FieldLabel}"/>
          <DockPanel Margin="0,2,0,0">
            <Button Content="Find" DockPanel.Dock="Right" Command="{Binding FindBacklogCommand}"
                    Style="{StaticResource MiniGhostButton}" Margin="6,0,0,0" Padding="16,5"/>
            <TextBox Text="{Binding BacklogCode, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Type any part of the backlog code, then Find"/>
          </DockPanel>
          <TextBlock Text="{Binding LoadError}" Foreground="{StaticResource Danger}" TextWrapping="Wrap"
                     FontSize="12" Margin="0,4,0,0"
                     Visibility="{Binding LoadError, Converter={StaticResource NullToCollapsedConverter}}"/>

          <!-- 2) Tasks as checkboxes -->
          <TextBlock Text="Tasks (check the ones to fill)" Style="{StaticResource FieldLabel}" Margin="0,10,0,0"/>
          <Border BorderBrush="{StaticResource BorderStrong}" BorderThickness="1" CornerRadius="6"
                  Background="{StaticResource Surface}" Height="116" Padding="4" Margin="0,2,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding Tasks}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <CheckBox Content="{Binding TaskName}" IsChecked="{Binding IsChecked}" Margin="5,3"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Border>

          <!-- 3) Distribution mode -->
          <TextBlock Text="Distribution" Style="{StaticResource FieldLabel}" Margin="0,10,0,0"/>
          <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
            <RadioButton Content="Split evenly" IsChecked="True" GroupName="Mode" Margin="0,0,16,0"
                         VerticalContentAlignment="Center" Command="{Binding SetDistributeEvenCommand}"/>
            <RadioButton Content="Full 8h" GroupName="Mode" VerticalContentAlignment="Center"
                         Command="{Binding SetFull8hCommand}"/>
          </StackPanel>

          <!-- 4) Date range + total -->
          <Grid Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="12"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
              <TextBlock Text="From" Style="{StaticResource FieldLabel}"/>
              <DatePicker SelectedDate="{Binding From, Converter={StaticResource DateOnly}}" Margin="0,2,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
              <TextBlock Text="To" Style="{StaticResource FieldLabel}"/>
              <DatePicker SelectedDate="{Binding To, Converter={StaticResource DateOnly}}" Margin="0,2,0,0"/>
            </StackPanel>
          </Grid>

          <TextBlock Text="Total hours (Split evenly only)" Style="{StaticResource FieldLabel}" Margin="0,10,0,0"/>
          <TextBox Text="{Binding TotalHours, UpdateSourceTrigger=PropertyChanged}" Width="120"
                   HorizontalAlignment="Left" Margin="0,2,0,0"/>

          <DockPanel Margin="0,12,0,0">
            <Button Content="Preview" DockPanel.Dock="Left" Command="{Binding BuildPreviewCommand}"
                    Width="120" HorizontalAlignment="Left"/>
            <TextBlock Text="{Binding PreviewError}" Foreground="{StaticResource Danger}" TextWrapping="Wrap"
                       FontSize="12" VerticalAlignment="Center" Margin="10,0,0,0"/>
          </DockPanel>
        </StackPanel>

        <!-- 5) Preview (fills remaining height; the grid scrolls) -->
        <DockPanel Grid.Row="1" Margin="0,12,0,0">
          <TextBlock DockPanel.Dock="Top" Text="Preview" Style="{StaticResource FieldLabel}"/>
          <Border BorderBrush="{StaticResource BorderStrong}" BorderThickness="1" CornerRadius="6"
                  Margin="0,2,0,0" ClipToBounds="True">
            <DataGrid ItemsSource="{Binding PreviewCells}" AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" VerticalScrollBarVisibility="Auto" BorderThickness="0">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Task"  Binding="{Binding TaskName}" Width="*"/>
                <DataGridTextColumn Header="Date"  Binding="{Binding Date, StringFormat='yyyy-MM-dd'}" Width="Auto"/>
                <DataGridTextColumn Header="Hours" Binding="{Binding Hours, StringFormat=N1}" Width="Auto"/>
              </DataGrid.Columns>
            </DataGrid>
          </Border>
        </DockPanel>
      </Grid>
    </DockPanel>
  </Border>
</Window>
