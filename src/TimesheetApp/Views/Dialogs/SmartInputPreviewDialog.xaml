<Window x:Class="TimesheetApp.Views.Dialogs.SmartInputPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart fill" Width="460" Height="600" WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBg}">
  <!-- DataContext is the TimesheetViewModel.SmartInput (SmartInputPanelVm) -->
  <DockPanel Margin="14" LastChildFill="True">

    <!-- Confirm / Cancel pinned to the bottom -->
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
      <Button Content="Confirm" Command="{Binding ApplyCommand}" Width="100" IsDefault="True"/>
      <Button Content="Cancel" IsCancel="True" Style="{StaticResource GhostButton}" Width="100" Margin="8,0,0,0"/>
    </StackPanel>

    <StackPanel DockPanel.Dock="Top">
      <!-- 1) Backlog code -> Find -->
      <TextBlock Text="Backlog code" FontWeight="SemiBold"/>
      <DockPanel Margin="0,2,0,2">
        <Button Content="Find" DockPanel.Dock="Right" Command="{Binding FindBacklogCommand}"
                Style="{StaticResource MiniGhostButton}" Margin="6,0,0,0" Padding="14,5"/>
        <TextBox Text="{Binding BacklogCode, UpdateSourceTrigger=PropertyChanged}"
                 VerticalContentAlignment="Center"/>
      </DockPanel>
      <TextBlock Text="{Binding LoadError}" Foreground="{StaticResource Danger}" TextWrapping="Wrap"
                 Visibility="{Binding LoadError, Converter={StaticResource NullToCollapsedConverter}}"
                 Margin="0,0,0,4"/>

      <!-- 2) Tasks as checkboxes -->
      <TextBlock Text="Tasks (check the ones to fill)" FontWeight="SemiBold" Margin="0,6,0,2"/>
      <Border BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6"
              Background="{StaticResource Surface}" Height="130" Padding="4">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding Tasks}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <CheckBox Content="{Binding TaskName}" IsChecked="{Binding IsChecked}" Margin="4,3"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>

      <!-- 3) Mode + dates + total -->
      <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
        <RadioButton Content="Split evenly" IsChecked="True" GroupName="Mode" Margin="0,0,14,0"
                     Command="{Binding SetDistributeEvenCommand}"/>
        <RadioButton Content="Full 8h" GroupName="Mode" Command="{Binding SetFull8hCommand}"/>
      </StackPanel>

      <Grid Margin="0,2,0,4">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="10"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
          <TextBlock Text="From"/>
          <DatePicker SelectedDate="{Binding From, Converter={StaticResource DateOnly}}"/>
        </StackPanel>
        <StackPanel Grid.Column="2">
          <TextBlock Text="To"/>
          <DatePicker SelectedDate="{Binding To, Converter={StaticResource DateOnly}}"/>
        </StackPanel>
      </Grid>

      <TextBlock Text="Total hours (Split evenly only)" Margin="0,2,0,0"/>
      <TextBox Text="{Binding TotalHours, UpdateSourceTrigger=PropertyChanged}" Width="120"
               HorizontalAlignment="Left" VerticalContentAlignment="Center"/>

      <Button Content="Preview" Command="{Binding BuildPreviewCommand}" Margin="0,10,0,4"
              Width="120" HorizontalAlignment="Left"/>
      <TextBlock Text="{Binding PreviewError}" Foreground="{StaticResource Danger}" TextWrapping="Wrap"/>
    </StackPanel>

    <!-- 4) Preview of what will be written -->
    <DataGrid ItemsSource="{Binding PreviewCells}" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,8,0,0">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Task"  Binding="{Binding TaskName}" Width="*"/>
        <DataGridTextColumn Header="Date"  Binding="{Binding Date, StringFormat='yyyy-MM-dd'}" Width="Auto"/>
        <DataGridTextColumn Header="Hours" Binding="{Binding Hours, StringFormat=N1}" Width="Auto"/>
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</Window>
