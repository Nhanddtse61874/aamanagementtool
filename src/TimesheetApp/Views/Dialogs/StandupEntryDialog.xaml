<Window x:Class="TimesheetApp.Views.Dialogs.StandupEntryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add standup entry" Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">
  <!-- DataContext = StandupDraftVm (Backlogs/Tasks/SelectedBacklog/SelectedTask/BacklogCode/...). -->
  <Border Background="{StaticResource Surface}" CornerRadius="12" BorderBrush="{StaticResource Border}"
          BorderThickness="1" Margin="12">
    <Border.Effect>
      <DropShadowEffect Color="#0F172A" Opacity="0.3" BlurRadius="24" ShadowDepth="4" Direction="270"/>
    </Border.Effect>
    <DockPanel>
      <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBg}" CornerRadius="12,12,0,0"
              Padding="20,14" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
        <TextBlock x:Name="HeaderText" Text="Add standup entry" FontWeight="Bold" FontSize="16"
                   Foreground="{StaticResource TextPrimary}"/>
      </Border>
      <Border DockPanel.Dock="Bottom" Background="{StaticResource HeaderBg}" CornerRadius="0,0,12,12"
              Padding="20,12" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Content="Cancel" Style="{StaticResource GhostButton}" Padding="18,6" Margin="0,0,8,0" IsCancel="True"/>
          <Button Content="Add" Padding="22,6" IsDefault="True" Click="OnAdd"/>
        </StackPanel>
      </Border>
      <StackPanel Margin="20,16">
        <TextBlock Text="Section" Style="{StaticResource FieldLabel}"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
          <RadioButton Content="Yesterday" GroupName="section" Margin="0,0,18,0" VerticalContentAlignment="Center"
                       IsChecked="{Binding Section, Converter={StaticResource StringMatch}, ConverterParameter=yesterday}"/>
          <RadioButton Content="Today" GroupName="section" VerticalContentAlignment="Center"
                       IsChecked="{Binding Section, Converter={StaticResource StringMatch}, ConverterParameter=today}"/>
        </StackPanel>

        <TextBlock Text="Backlog (pick existing, or type a new code)" Style="{StaticResource FieldLabel}"/>
        <Grid Margin="0,0,0,8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <ComboBox Grid.Column="0" ItemsSource="{Binding Backlogs}" DisplayMemberPath="BacklogCode"
                    SelectedItem="{Binding SelectedBacklog}" ToolTip="Pick an existing backlog"/>
          <TextBox Grid.Column="1" Margin="6,0,0,0"
                   Text="{Binding BacklogCode, UpdateSourceTrigger=PropertyChanged}"
                   ToolTip="Backlog code (type here for an ad-hoc backlog)"/>
        </Grid>

        <TextBlock Text="Task (pick from backlog, or type)" Style="{StaticResource FieldLabel}"/>
        <Grid Margin="0,0,0,8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <ComboBox Grid.Column="0" ItemsSource="{Binding Tasks}" DisplayMemberPath="TaskName"
                    SelectedItem="{Binding SelectedTask}" ToolTip="Pick a task of the backlog"/>
          <TextBox Grid.Column="1" Margin="6,0,0,0"
                   Text="{Binding TaskText, UpdateSourceTrigger=PropertyChanged}"
                   ToolTip="Task name (type here to add your own)"/>
        </Grid>

        <TextBlock Text="What did you do / are you doing" Style="{StaticResource FieldLabel}"/>
        <TextBox Margin="0,0,0,8" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="56" VerticalContentAlignment="Top"/>

        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" Margin="0,0,8,0">
            <TextBlock Text="Deadline (optional)" Style="{StaticResource FieldLabel}"/>
            <DatePicker SelectedDate="{Binding Deadline}"/>
          </StackPanel>
          <StackPanel Grid.Column="1">
            <TextBlock Text="Status" Style="{StaticResource FieldLabel}"/>
            <ComboBox Width="140" ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding Status}"/>
          </StackPanel>
        </Grid>

        <TextBlock x:Name="ErrorText" Foreground="{StaticResource Danger}" FontSize="12" Margin="0,8,0,0"
                   TextWrapping="Wrap" Visibility="Collapsed"/>
      </StackPanel>
    </DockPanel>
  </Border>
</Window>
