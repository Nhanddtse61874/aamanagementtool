<Window x:Class="TimesheetApp.Views.Dialogs.StandupIssueDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add issue" Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">
  <Border Background="{DynamicResource Surface}" CornerRadius="12" BorderBrush="{DynamicResource Border}"
          BorderThickness="1" Margin="12">
    <Border.Effect>
      <DropShadowEffect Color="#0F172A" Opacity="0.3" BlurRadius="24" ShadowDepth="4" Direction="270"/>
    </Border.Effect>
    <DockPanel>
      <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBg}" CornerRadius="12,12,0,0"
              Padding="20,14" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
        <TextBlock Text="Add issue" FontWeight="Bold" FontSize="17" Foreground="{DynamicResource TextPrimary}"/>
      </Border>
      <Border DockPanel.Dock="Bottom" Background="{DynamicResource HeaderBg}" CornerRadius="0,0,12,12"
              Padding="20,12" BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Content="Cancel" Style="{StaticResource GhostButton}" Padding="18,6" Margin="0,0,8,0" IsCancel="True"/>
          <Button Content="Add" Padding="22,6" IsDefault="True" Click="OnAdd"/>
        </StackPanel>
      </Border>
      <StackPanel Margin="20,16">
        <TextBlock Text="Issue" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="IssueBox" Margin="0,0,0,8" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="48"
                 VerticalContentAlignment="Top"/>

        <TextBlock Text="Solution (leave blank = pending discussion)" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="SolutionBox" Margin="0,0,0,8" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="48"
                 VerticalContentAlignment="Top"/>

        <TextBlock Text="Status" Style="{StaticResource FieldLabel}"/>
        <ComboBox x:Name="StatusBox" Width="160" HorizontalAlignment="Left"/>

        <TextBlock x:Name="ErrorText" Text="Please enter the issue." Foreground="{DynamicResource Danger}"
                   FontSize="12" Margin="0,8,0,0" Visibility="Collapsed"/>
      </StackPanel>
    </DockPanel>
  </Border>
</Window>
