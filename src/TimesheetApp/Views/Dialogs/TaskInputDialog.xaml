<Window x:Class="TimesheetApp.Views.Dialogs.TaskInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add task" Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">
  <Border Background="{StaticResource Surface}" CornerRadius="12" BorderBrush="{StaticResource Border}"
          BorderThickness="1" Margin="12">
    <Border.Effect>
      <DropShadowEffect Color="#0F172A" Opacity="0.3" BlurRadius="24" ShadowDepth="4" Direction="270"/>
    </Border.Effect>
    <DockPanel>
      <!-- Header -->
      <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBg}" CornerRadius="12,12,0,0"
              Padding="20,14" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
        <TextBlock x:Name="HeaderText" Text="Add task" FontWeight="Bold" FontSize="16"
                   Foreground="{StaticResource TextPrimary}"/>
      </Border>
      <!-- Footer -->
      <Border DockPanel.Dock="Bottom" Background="{StaticResource HeaderBg}" CornerRadius="0,0,12,12"
              Padding="20,12" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Content="Cancel" Style="{StaticResource GhostButton}" Padding="18,6" Margin="0,0,8,0"
                  IsCancel="True"/>
          <Button Content="Add" Padding="22,6" IsDefault="True" Click="OnAdd"/>
        </StackPanel>
      </Border>
      <!-- Body -->
      <StackPanel Margin="20,16">
        <TextBlock x:Name="LabelText" Text="Task name" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="NameBox"/>
        <TextBlock x:Name="ErrorText" Text="Please enter a task name." Foreground="{StaticResource Danger}"
                   FontSize="12" Margin="0,6,0,0" Visibility="Collapsed"/>
      </StackPanel>
    </DockPanel>
  </Border>
</Window>
