<UserControl x:Class="TimesheetApp.Views.Tabs.DailyBoardTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- DataContext = DailyReportViewModel. Read-only team board for the selected day: one card per active
       user (dynamic count), each showing Yesterday/Today entries + issues. Tokens reuse Theme.xaml. -->
  <UserControl.Resources>

    <!-- One entry inside a section (DataContext = StandupEntryView). -->
    <DataTemplate x:Key="BoardEntryTemplate">
      <Border BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="0,7">
        <StackPanel>
          <DockPanel>
            <Border DockPanel.Dock="Right" Background="{StaticResource BadgeGrayBg}" CornerRadius="10"
                    Padding="9,2" VerticalAlignment="Top">
              <TextBlock Text="{Binding Entry.Status}" FontSize="12" FontWeight="SemiBold"
                         Foreground="{StaticResource BadgeGrayFg}"/>
            </Border>
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Entry.BacklogCode}" FontWeight="Bold" Foreground="{StaticResource Accent}"/>
                <TextBlock Text="·" Margin="6,0" Foreground="{StaticResource TextSecondary}"/>
                <TextBlock Text="{Binding Entry.TaskText}" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Entry.Deadline, StringFormat='· due {0:yyyy-MM-dd}'}" Margin="8,0,0,0"
                           FontSize="12" Foreground="{StaticResource TextSecondary}"/>
              </StackPanel>
              <TextBlock Text="{Binding Entry.Description}" Margin="0,3,8,0"
                         Foreground="{StaticResource TextSecondary}" FontSize="13"/>
            </StackPanel>
          </DockPanel>
          <ItemsControl ItemsSource="{Binding Issues}" Margin="12,5,0,0">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <TextBlock Margin="0,1" Foreground="{StaticResource AmberFg}" FontSize="13">
                  <Run Text="⚠ ["/><Run Text="{Binding Status, Mode=OneWay}"/><Run Text="] "/>
                  <Run Text="{Binding IssueText, Mode=OneWay}"/>
                  <Run Text="  →  " Foreground="{StaticResource TextSecondary}"/>
                  <Run Text="{Binding SolutionText, Mode=OneWay, TargetNullValue='(pending)'}"/>
                </TextBlock>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>
    </DataTemplate>

    <!-- One user card (DataContext = UserStandup). -->
    <DataTemplate x:Key="UserCardTemplate">
      <Border Style="{StaticResource Card}">
        <StackPanel>
          <!-- user header: avatar + name -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Border Background="{StaticResource Accent}" CornerRadius="13" Width="26" Height="26" Margin="0,0,9,0">
              <TextBlock Text="{Binding UserName, Converter={StaticResource Initial}}" Foreground="White"
                         FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="{Binding UserName}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
          </StackPanel>

          <Border Background="{StaticResource TableHeaderBg}" CornerRadius="5" Padding="9,4">
            <TextBlock Text="Yesterday" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TableHeaderText}"/>
          </Border>
          <ItemsControl ItemsSource="{Binding Yesterday}" ItemTemplate="{StaticResource BoardEntryTemplate}"
                        Margin="0,2,0,0"/>

          <Border Background="{StaticResource TableHeaderBg}" CornerRadius="5" Padding="9,4" Margin="0,10,0,0">
            <TextBlock Text="Today" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TableHeaderText}"/>
          </Border>
          <ItemsControl ItemsSource="{Binding Today}" ItemTemplate="{StaticResource BoardEntryTemplate}"
                        Margin="0,2,0,0"/>
        </StackPanel>
      </Border>
    </DataTemplate>
  </UserControl.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="22,4,22,16">
    <ItemsControl ItemsSource="{Binding Board}" ItemTemplate="{StaticResource UserCardTemplate}"/>
  </ScrollViewer>
</UserControl>
