<UserControl x:Class="TimesheetApp.Views.Tabs.DailyInputTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- DataContext = DailyReportViewModel. Two side-by-side sections (Yesterday / Today); each lists the
       signed-in user's entries (delete + issues) and an add-row form shown only when the day is editable.
       Visual tokens reuse Theme.xaml (Card, FieldLabel, ToolbarButton, MiniGhostButton, badges). -->
  <UserControl.Resources>

    <!-- One existing standup entry: read-only fields + collaborative issues + delete (if editable). -->
    <DataTemplate x:Key="EntryTemplate">
      <Border Style="{StaticResource Card}" Margin="0,0,0,10">
        <StackPanel>
          <!-- header: code · task + status badge -->
          <DockPanel>
            <Border DockPanel.Dock="Right" Background="{StaticResource BadgeGrayBg}" CornerRadius="10"
                    Padding="9,2" VerticalAlignment="Top">
              <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold"
                         Foreground="{StaticResource BadgeGrayFg}"/>
            </Border>
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding RequestCode}" FontWeight="Bold" Foreground="{StaticResource Accent}"/>
                <TextBlock Text="·" Margin="6,0" Foreground="{StaticResource TextSecondary}"/>
                <TextBlock Text="{Binding TaskText}" FontWeight="SemiBold"/>
              </StackPanel>
              <TextBlock Text="{Binding Description}" Margin="0,4,8,0"
                         Foreground="{StaticResource TextSecondary}" FontSize="13"/>
              <TextBlock Text="{Binding DeadlineText, StringFormat='Deadline: {0}'}" FontSize="12"
                         Margin="0,4,0,0" Foreground="{StaticResource TextSecondary}"
                         Visibility="{Binding DeadlineText, Converter={StaticResource NullToCollapsedConverter}}"/>
            </StackPanel>
          </DockPanel>

          <!-- issues (amber; collaborative — editable anytime) -->
          <ItemsControl ItemsSource="{Binding Issues}" Margin="0,10,0,0">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Background="{StaticResource AmberBg}" BorderBrush="{StaticResource AmberBorder}"
                        BorderThickness="1" CornerRadius="6" Padding="9" Margin="0,0,0,6">
                  <StackPanel>
                    <TextBlock Text="{Binding IssueText, StringFormat='⚠ {0}'}"
                               FontWeight="SemiBold" Foreground="{StaticResource AmberFg}"/>
                    <Grid Margin="0,6,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                      </Grid.ColumnDefinitions>
                      <TextBox Grid.Column="0" Text="{Binding SolutionText, UpdateSourceTrigger=PropertyChanged}"
                               ToolTip="Solution (leave blank = pending discussion)"/>
                      <ComboBox Grid.Column="1" Width="105" Margin="6,0,0,0"
                                ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding Status}"/>
                      <Button Grid.Column="2" Content="Save" Style="{StaticResource MiniGhostButton}"
                              Command="{Binding SaveCommand}" Margin="6,0,0,0"/>
                      <Button Grid.Column="3" Content="✕" Style="{StaticResource MiniGhostButton}"
                              Command="{Binding DeleteCommand}" Margin="6,0,0,0"/>
                    </Grid>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- add-issue + delete-entry row -->
          <Grid Margin="0,2,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding NewIssueText, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Describe an issue, then click + Issue"/>
            <Button Grid.Column="1" Content="+ Issue" Style="{StaticResource MiniGhostButton}"
                    Command="{Binding AddIssueCommand}" Margin="6,0,0,0"/>
            <Button Grid.Column="2" Content="Delete" Style="{StaticResource MiniGhostButton}"
                    Command="{Binding DeleteCommand}" Margin="6,0,0,0"
                    Visibility="{Binding Editable, Converter={StaticResource BoolToVisibleConverter}}"/>
          </Grid>
        </StackPanel>
      </Border>
    </DataTemplate>

    <!-- The add-new-entry form for one section (bound to a StandupDraftVm). -->
    <DataTemplate x:Key="DraftTemplate">
      <Border Style="{StaticResource StatCard}">
        <StackPanel>
          <TextBlock Text="ADD ENTRY" Style="{StaticResource StatLabel}" Margin="0,0,0,6"/>

          <TextBlock Text="Request" Style="{StaticResource FieldLabel}"/>
          <ComboBox Margin="0,0,0,8" IsEditable="True" ItemsSource="{Binding Requests}"
                    SelectedItem="{Binding SelectedRequest}" DisplayMemberPath="RequestCode"
                    Text="{Binding RequestCode, UpdateSourceTrigger=PropertyChanged}"
                    ToolTip="Pick an existing request or type a new code (ad-hoc)"/>

          <TextBlock Text="Task" Style="{StaticResource FieldLabel}"/>
          <ComboBox Margin="0,0,0,8" IsEditable="True" ItemsSource="{Binding Tasks}"
                    DisplayMemberPath="TaskName"
                    Text="{Binding TaskText, UpdateSourceTrigger=PropertyChanged}"
                    ToolTip="Pick a task of the request or type one"/>

          <TextBlock Text="What did you do / are you doing" Style="{StaticResource FieldLabel}"/>
          <TextBox Margin="0,0,0,8" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                   AcceptsReturn="True" TextWrapping="Wrap" MinHeight="42"
                   VerticalContentAlignment="Top"/>

          <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
              <TextBlock Text="Deadline (optional)" Style="{StaticResource FieldLabel}"/>
              <DatePicker SelectedDate="{Binding Deadline}"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
              <TextBlock Text="Status" Style="{StaticResource FieldLabel}"/>
              <ComboBox Width="130" ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding Status}"/>
            </StackPanel>
          </Grid>

          <Button Content="&#10133; Add" Style="{StaticResource ToolbarButton}" HorizontalAlignment="Left"
                  Command="{Binding AddCommand}"/>
        </StackPanel>
      </Border>
    </DataTemplate>
  </UserControl.Resources>

  <Grid Margin="22,4,22,16">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- Yesterday -->
    <DockPanel Grid.Column="0" Margin="0,0,9,0">
      <TextBlock DockPanel.Dock="Top" Text="Yesterday" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <ItemsControl ItemsSource="{Binding MyYesterday}" ItemTemplate="{StaticResource EntryTemplate}"/>
          <ContentControl Content="{Binding NewYesterday}" ContentTemplate="{StaticResource DraftTemplate}"
                          Visibility="{Binding CanEditSelectedDay, Converter={StaticResource BoolToVisibleConverter}}"/>
        </StackPanel>
      </ScrollViewer>
    </DockPanel>

    <!-- Today -->
    <DockPanel Grid.Column="1" Margin="9,0,0,0">
      <TextBlock DockPanel.Dock="Top" Text="Today" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <ItemsControl ItemsSource="{Binding MyToday}" ItemTemplate="{StaticResource EntryTemplate}"/>
          <ContentControl Content="{Binding NewToday}" ContentTemplate="{StaticResource DraftTemplate}"
                          Visibility="{Binding CanEditSelectedDay, Converter={StaticResource BoolToVisibleConverter}}"/>
        </StackPanel>
      </ScrollViewer>
    </DockPanel>
  </Grid>
</UserControl>
