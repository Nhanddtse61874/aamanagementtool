<UserControl x:Class="TimesheetApp.Views.Tabs.DailyInputTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- DataContext = DailyReportViewModel. Each section lists the signed-in user's entries; adding an
       entry or an issue opens a modal dialog (kept out of this surface). Existing issues stay inline-
       editable (solution + status) since that is the collaborative "fill after discussion" workflow. -->
  <UserControl.Resources>

    <!-- One existing standup entry (DataContext = StandupEntryRowVm). -->
    <DataTemplate x:Key="EntryTemplate">
      <Border Style="{StaticResource Card}" Margin="0,0,0,10">
        <StackPanel>
          <DockPanel>
            <Border DockPanel.Dock="Right" Background="{StaticResource BadgeGrayBg}" CornerRadius="10"
                    Padding="9,2" VerticalAlignment="Top">
              <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold"
                         Foreground="{StaticResource BadgeGrayFg}"/>
            </Border>
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding BacklogCode}" FontWeight="Bold" Foreground="{StaticResource Accent}"/>
                <TextBlock Text="·" Margin="6,0" Foreground="{StaticResource TextSecondary}"/>
                <TextBlock Text="{Binding TaskText}" FontWeight="SemiBold"/>
              </StackPanel>
              <TextBlock Text="{Binding Description}" Margin="0,4,8,0"
                         Foreground="{StaticResource TextSecondary}" FontSize="13"/>
              <TextBlock Text="{Binding DeadlineText, StringFormat='Deadline: {0}'}" FontSize="12"
                         Margin="0,4,0,0" Foreground="{StaticResource TextSecondary}"
                         Visibility="{Binding DeadlineText, Converter={StaticResource NullToCollapsedConverter}}"/>
            </StackPanel>
          </DockPanel>

          <!-- issues: existing ones are inline-editable (solution + status); add via dialog -->
          <Border Background="{StaticResource Border}" Height="1" Margin="0,12,0,8"/>
          <DockPanel>
            <Button DockPanel.Dock="Right" Content="&#10133; Issue" Style="{StaticResource MiniGhostButton}"
                    Click="OnAddIssue"/>
            <TextBlock Text="ISSUES" Style="{StaticResource StatLabel}" VerticalAlignment="Center"/>
          </DockPanel>

          <ItemsControl ItemsSource="{Binding Issues}" Margin="0,6,0,0">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <!-- Amber "warning" until a solution is saved; flips to green "resolved" (✓) once it has one. -->
                <Border x:Name="issueBox" Background="{StaticResource AmberBg}"
                        BorderBrush="{StaticResource AmberBorder}" BorderThickness="1"
                        CornerRadius="6" Padding="9" Margin="0,0,0,6">
                  <StackPanel>
                    <!-- header: status icon + issue text + delete -->
                    <DockPanel>
                      <Button DockPanel.Dock="Right" Content="✕" Style="{StaticResource MiniGhostButton}"
                              Command="{Binding DeleteCommand}" ToolTip="Delete issue" VerticalAlignment="Top"/>
                      <TextBlock x:Name="issueIcon" DockPanel.Dock="Left" Text="⚠" FontWeight="Bold"
                                 Foreground="{StaticResource AmberFg}" Margin="0,0,7,0" VerticalAlignment="Top"/>
                      <TextBlock x:Name="issueText" Text="{Binding IssueText}" FontWeight="SemiBold"
                                 Foreground="{StaticResource AmberFg}" TextWrapping="Wrap"/>
                    </DockPanel>

                    <!-- no solution yet: placeholder + "add solution" button (no empty input) -->
                    <DockPanel Margin="0,8,0,0"
                               Visibility="{Binding ShowNoSolution, Converter={StaticResource BoolToVisibleConverter}}">
                      <Button DockPanel.Dock="Right" Content="&#10133; Nhập solution"
                              Style="{StaticResource MiniGhostButton}" Command="{Binding BeginEditSolutionCommand}"/>
                      <TextBlock Text="Chưa có solution" FontStyle="Italic" FontSize="12"
                                 Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                    </DockPanel>

                    <!-- solution editor: while adding one, or once it exists (then the row is "resolved") -->
                    <StackPanel Margin="0,8,0,0"
                                Visibility="{Binding ShowSolutionEditor, Converter={StaticResource BoolToVisibleConverter}}">
                      <TextBlock Text="Solution" Style="{StaticResource FieldLabel}"/>
                      <Grid Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="Auto"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding SolutionText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Describe how the issue was solved"/>
                        <ComboBox Grid.Column="1" Width="105" Margin="6,0,0,0"
                                  ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding Status}"/>
                        <Button Grid.Column="2" Content="Save" Style="{StaticResource MiniGhostButton}"
                                Command="{Binding SaveCommand}" Margin="6,0,0,0"/>
                      </Grid>
                    </StackPanel>
                  </StackPanel>
                </Border>

                <DataTemplate.Triggers>
                  <DataTrigger Binding="{Binding HasSolution}" Value="True">
                    <Setter TargetName="issueBox" Property="Background" Value="{StaticResource BadgeGreenBg}"/>
                    <Setter TargetName="issueBox" Property="BorderBrush" Value="{StaticResource ResolvedBorder}"/>
                    <Setter TargetName="issueIcon" Property="Text" Value="&#10003;"/>
                    <Setter TargetName="issueIcon" Property="Foreground" Value="{StaticResource BadgeGreenFg}"/>
                    <Setter TargetName="issueText" Property="Foreground" Value="{StaticResource BadgeGreenFg}"/>
                  </DataTrigger>
                </DataTemplate.Triggers>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <Button Content="Delete entry" Style="{StaticResource MiniGhostButton}" HorizontalAlignment="Right"
                  Margin="0,2,0,0" Command="{Binding DeleteCommand}"
                  Visibility="{Binding Editable, Converter={StaticResource BoolToVisibleConverter}}"/>
        </StackPanel>
      </Border>
    </DataTemplate>
  </UserControl.Resources>

  <Grid Margin="22,4,22,16">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- Yesterday -->
    <DockPanel Grid.Column="0" Margin="0,0,9,0">
      <TextBlock DockPanel.Dock="Top" Text="Yesterday" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <ItemsControl ItemsSource="{Binding MyYesterday}" ItemTemplate="{StaticResource EntryTemplate}"/>
          <Button Content="&#10133; Add entry" Style="{StaticResource ToolbarButton}" HorizontalAlignment="Left"
                  Tag="yesterday" Click="OnAddEntry"
                  Visibility="{Binding CanEditSelectedDay, Converter={StaticResource BoolToVisibleConverter}}"/>
        </StackPanel>
      </ScrollViewer>
    </DockPanel>

    <!-- Today -->
    <DockPanel Grid.Column="1" Margin="9,0,0,0">
      <TextBlock DockPanel.Dock="Top" Text="Today" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <ItemsControl ItemsSource="{Binding MyToday}" ItemTemplate="{StaticResource EntryTemplate}"/>
          <Button Content="&#10133; Add entry" Style="{StaticResource ToolbarButton}" HorizontalAlignment="Left"
                  Tag="today" Click="OnAddEntry"
                  Visibility="{Binding CanEditSelectedDay, Converter={StaticResource BoolToVisibleConverter}}"/>
        </StackPanel>
      </ScrollViewer>
    </DockPanel>
  </Grid>
</UserControl>
