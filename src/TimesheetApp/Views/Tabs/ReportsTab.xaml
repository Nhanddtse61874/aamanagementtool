<UserControl x:Class="TimesheetApp.Views.Tabs.ReportsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:m="clr-namespace:TimesheetApp.Models"
             xmlns:conv="clr-namespace:TimesheetApp.Views.Converters"
             xmlns:ctrl="clr-namespace:TimesheetApp.Views.Controls">
  <UserControl.Resources>
    <!-- Local resource: DateOnly<->DateTime? for DatePicker bindings. Declared here (not App.xaml)
         so the StaticResource resolves at runtime without cross-phase dependency. -->
    <conv:DateOnlyConverter x:Key="DateOnlyConverter"/>
  </UserControl.Resources>

  <DockPanel Margin="8">

    <!-- RPT-04 banner: visible only when BannerText is non-empty -->
    <Border DockPanel.Dock="Top" Background="{StaticResource AmberBg}" BorderBrush="{StaticResource AmberBorder}"
            BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,0,10">
      <Border.Style>
        <Style TargetType="Border">
          <Setter Property="Visibility" Value="Visible"/>
          <Style.Triggers>
            <DataTrigger Binding="{Binding BannerText}" Value="">
              <Setter Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <!-- D1: one line PER USER (not the flattened BannerText), capped height + scroll when the list is long. -->
      <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="&#9888; Missing time logs" FontWeight="SemiBold"
                   Foreground="{StaticResource AmberFg}" Margin="0,0,0,4"/>
        <ScrollViewer MaxHeight="96" VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding MissingBanner}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding UserName}" TextWrapping="Wrap"
                           Foreground="{StaticResource AmberFg}" Margin="0,1"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </DockPanel>
    </Border>

    <!-- Controls: report target + week + month + project filter (grids auto-load on any change) + Export.
         A WrapPanel so the controls flow onto a second line on narrow windows instead of clipping. -->
    <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,8">
      <StackPanel Orientation="Horizontal" Margin="0,0,16,6">
        <TextBlock Text="Report for:" VerticalAlignment="Center" Margin="0,0,4,0"/>
        <ComboBox Width="160" ItemsSource="{Binding Targets}"
                  SelectedItem="{Binding SelectedTarget}" DisplayMemberPath="Display"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" Margin="0,0,16,6">
        <TextBlock Text="Week (Mon):" VerticalAlignment="Center" Margin="0,0,4,0"/>
        <DatePicker Width="118" SelectedDate="{Binding SelectedWeekMonday, Converter={StaticResource DateOnlyConverter}}"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" Margin="0,0,16,6">
        <TextBlock Text="Month:" VerticalAlignment="Center" Margin="0,0,4,0"/>
        <DatePicker Width="118" SelectedDate="{Binding SelectedMonth, Converter={StaticResource DateOnlyConverter}}"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" Margin="0,0,16,6">
        <TextBlock Text="Project:" VerticalAlignment="Center" Margin="0,0,4,0"/>
        <ComboBox Width="100" ItemsSource="{Binding Projects}" SelectedItem="{Binding SelectedProject}"/>
      </StackPanel>
      <!-- P10 (TM-07): multi-team checkbox filter (hidden for single-team users). -->
      <StackPanel Orientation="Horizontal" Margin="0,0,16,6">
        <ctrl:TeamFilter DataContext="{Binding TeamFilter}" VerticalAlignment="Center"/>
      </StackPanel>
      <Button Content="&#11015; Export to Excel" Click="OnExportExcel"
              Style="{StaticResource ToolbarButton}" Margin="0,0,0,6"
              ToolTip="Export the selected month (and project) to an .xlsx file"/>
    </WrapPanel>

    <!-- Summary stat cards (computed from the loaded weekly rows) -->
    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <Border Grid.Column="0" Style="{StaticResource StatCard}" Margin="0,0,5,0">
        <StackPanel>
          <TextBlock Style="{StaticResource StatLabel}" Text="WEEK TOTAL"/>
          <TextBlock Style="{StaticResource StatValue}" Text="{Binding WeekTotalText}"
                     Foreground="{StaticResource Accent}"/>
        </StackPanel>
      </Border>
      <Border Grid.Column="1" Style="{StaticResource StatCard}" Margin="5,0">
        <StackPanel>
          <TextBlock Style="{StaticResource StatLabel}" Text="AVG / DAY"/>
          <TextBlock Style="{StaticResource StatValue}" Text="{Binding AvgPerDayText}"/>
        </StackPanel>
      </Border>
      <Border Grid.Column="2" Style="{StaticResource StatCard}" Margin="5,0">
        <StackPanel>
          <TextBlock Style="{StaticResource StatLabel}" Text="DAYS LOGGED"/>
          <TextBlock Style="{StaticResource StatValue}" Text="{Binding DaysLoggedText}"/>
        </StackPanel>
      </Border>
      <Border Grid.Column="3" Margin="5,0,0,0" Background="{StaticResource AmberBg}"
              BorderBrush="{StaticResource AmberBorder}" BorderThickness="1" CornerRadius="8" Padding="14,11">
        <StackPanel>
          <TextBlock Style="{StaticResource StatLabel}" Text="&#9888; NOT LOGGED" Foreground="{StaticResource AmberFg}"/>
          <!-- Count of users with missing logs (the per-user detail lives in the banner above — no dup). -->
          <TextBlock Style="{StaticResource StatValue}" Text="{Binding MissingBanner.Count}"
                     Foreground="{StaticResource AmberFg}"/>
        </StackPanel>
      </Border>
    </Grid>

    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Left column: RPT-01 weekly grid + RPT-02 monthly grid -->
      <DockPanel Grid.Column="0" Margin="0,0,8,0">
        <TextBlock DockPanel.Dock="Top" Text="Weekly (by day · ticket · task)" FontWeight="Bold"/>
        <!-- RPT-01: one row per (date, ticket, task) with summed hours -->
        <DataGrid DockPanel.Dock="Top" Height="200" ItemsSource="{Binding WeeklyDetailRows}"
                  AutoGenerateColumns="False" IsReadOnly="True">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=ddd dd/MM}" Width="Auto" MinWidth="84"/>
            <DataGridTextColumn Header="Ticket" Binding="{Binding BacklogCode}" Width="*" MinWidth="100"/>
            <DataGridTextColumn Header="Task" Binding="{Binding TaskName}" Width="*" MinWidth="120"/>
            <DataGridTextColumn Header="Hours" Binding="{Binding TotalHours, StringFormat=N1}" Width="Auto" MinWidth="60"/>
          </DataGrid.Columns>
        </DataGrid>
        <TextBlock DockPanel.Dock="Top" Text="Monthly (by backlog / task)" FontWeight="Bold" Margin="0,8,0,0"/>
        <!-- RPT-02: one row per (RequestCode, Project, TaskName) with summed hours -->
        <DataGrid ItemsSource="{Binding MonthlyRows}" AutoGenerateColumns="False" IsReadOnly="True">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Backlog" Binding="{Binding BacklogCode}" Width="Auto" MinWidth="110"/>
            <DataGridTextColumn Header="Project" Binding="{Binding Project}" Width="Auto" MinWidth="90"/>
            <DataGridTextColumn Header="Task" Binding="{Binding TaskName}" Width="*" MinWidth="120"/>
            <DataGridTextColumn Header="Hours" Binding="{Binding TotalHours, StringFormat=N1}" Width="Auto" MinWidth="60"/>
          </DataGrid.Columns>
        </DataGrid>
      </DockPanel>

      <!-- Right column: RPT-03 drill-down TreeView (Project -> Request -> Task -> Date) -->
      <DockPanel Grid.Column="1">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
          <Button DockPanel.Dock="Right" Command="{Binding ToggleDrillExpandCommand}"
                  Style="{StaticResource ToolbarGhostButton}" Content="{Binding DrillToggleText}"
                  ToolTip="Expand / collapse the whole tree"/>
          <TextBlock Text="Drill-down (Project -> Backlog -> Task -> Date)" FontWeight="Bold"
                     VerticalAlignment="Center"/>
        </DockPanel>
        <TreeView ItemsSource="{Binding ProjectTree}">
          <TreeView.ItemContainerStyle>
            <!-- Expand/collapse-all: every node follows the shared DrillExpanded flag (OneWay so a
                 manual click on a single node still works between toggles). -->
            <Style TargetType="TreeViewItem">
              <Setter Property="IsExpanded"
                      Value="{Binding DataContext.DrillExpanded, Mode=OneWay,
                              RelativeSource={RelativeSource AncestorType=TreeView}}"/>
            </Style>
          </TreeView.ItemContainerStyle>
          <TreeView.Resources>
            <!-- Every level shows its rolled-up hours; the Date leaf shows the hours logged that day. -->
            <!-- Level 0: TeamNode — children are Projects (P10 TM-08; one node when a single team) -->
            <HierarchicalDataTemplate DataType="{x:Type m:TeamNode}" ItemsSource="{Binding Projects}">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding TeamName}" FontWeight="Bold"/>
                <TextBlock Text="{Binding TotalHours, StringFormat=' — {0:N1}h'}" FontWeight="Bold"
                           Foreground="{StaticResource TextSecondary}"/>
              </StackPanel>
            </HierarchicalDataTemplate>
            <!-- Level 1: ProjectNode — children are Backlogs -->
            <HierarchicalDataTemplate DataType="{x:Type m:ProjectNode}" ItemsSource="{Binding Backlogs}">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Project}" FontWeight="Bold"/>
                <TextBlock Text="{Binding TotalHours, StringFormat=' — {0:N1}h'}" FontWeight="Bold"
                           Foreground="{StaticResource TextSecondary}"/>
              </StackPanel>
            </HierarchicalDataTemplate>
            <!-- Level 2: BacklogNode — children are Tasks -->
            <HierarchicalDataTemplate DataType="{x:Type m:BacklogNode}" ItemsSource="{Binding Tasks}">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding BacklogCode}"/>
                <TextBlock Text="{Binding TotalHours, StringFormat=' — {0:N1}h'}"
                           Foreground="{StaticResource TextSecondary}"/>
              </StackPanel>
            </HierarchicalDataTemplate>
            <!-- Level 3: TaskNode — children are Dates -->
            <HierarchicalDataTemplate DataType="{x:Type m:TaskNode}" ItemsSource="{Binding Dates}">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding TaskName}"/>
                <TextBlock Text="{Binding TotalHours, StringFormat=' — {0:N1}h'}"
                           Foreground="{StaticResource TextSecondary}"/>
              </StackPanel>
            </HierarchicalDataTemplate>
            <!-- Level 4 leaf: DateEntry — date + hours logged that day -->
            <DataTemplate DataType="{x:Type m:DateEntry}">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Date, StringFormat='ddd, yyyy-MM-dd'}"
                           Foreground="{StaticResource TextSecondary}"/>
                <TextBlock Text="{Binding TotalHours, StringFormat=' — {0:N1}h'}" FontWeight="SemiBold"
                           Foreground="{StaticResource Accent}"/>
              </StackPanel>
            </DataTemplate>
          </TreeView.Resources>
        </TreeView>
      </DockPanel>
    </Grid>
  </DockPanel>
</UserControl>
