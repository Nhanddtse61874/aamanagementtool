<UserControl x:Class="TimesheetApp.Views.Tabs.RequestsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- REQ-01: search box + New Request button. Search is explicit (RefreshCommand button),
             not auto-query — per VM comment: "setter does NOT auto-refresh". -->
        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <Button Content="New Request" Command="{Binding BeginCreateCommand}"
                    DockPanel.Dock="Right" Padding="10,4" Margin="4,0,0,0"/>
            <Button Content="Search" Command="{Binding RefreshCommand}"
                    DockPanel.Dock="Right" Padding="10,4" Margin="4,0,0,0"/>
            <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"/>
        </DockPanel>

        <!-- REQ-01: request list. NOTE: NO delete-request button anywhere (REQ-04). -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding Requests}" AutoGenerateColumns="False"
                  IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Code" Binding="{Binding RequestCode}" Width="1.6*"/>
                <DataGridTextColumn Header="Project" Binding="{Binding Project}" Width="1.4*"/>
                <DataGridTextColumn Header="Tasks" Binding="{Binding TaskCount}" Width="80"/>
                <DataGridTemplateColumn Header="" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <!-- REQ-03: edit only — no Request delete affordance (REQ-04) -->
                            <Button Content="Edit" Style="{StaticResource MiniGhostButton}"
                                    HorizontalAlignment="Right" Margin="0,0,6,0"
                                    Command="{Binding DataContext.BeginEditCommand,
                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding Id}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- REQ-02/03: editor overlay — shown when Editor != null -->
        <Border Grid.RowSpan="2" Background="#80000000"
                Visibility="{Binding Editor,
                             Converter={StaticResource NullToCollapsedConverter}}">
            <Border Background="White" Width="480" Padding="16"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxHeight="600">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel DataContext="{Binding Editor}">
                        <TextBlock Text="Request" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>

                        <TextBlock Text="Code:"/>
                        <TextBox Text="{Binding RequestCode, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,2,0,6"/>

                        <TextBlock Text="Project:"/>
                        <TextBox Text="{Binding Project, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,2,0,6"/>

                        <!-- REQ-02: template picker (only meaningful in create mode) -->
                        <DockPanel Margin="0,4,0,4">
                            <Button Content="Apply Template"
                                    Command="{Binding ApplyTemplateCommand}"
                                    DockPanel.Dock="Right" Padding="8,4" Margin="4,0,0,0"/>
                            <ComboBox ItemsSource="{Binding TemplateNames}"
                                      SelectedItem="{Binding SelectedTemplateName}"/>
                        </DockPanel>

                        <!-- REQ-02/04: ordered editable task list with reorder + remove-task.
                             Remove/Up/Down commands are on the UserControl code-behind because
                             RemoveTask/MoveUp/MoveDown on RequestEditorViewModel are plain methods
                             (not [RelayCommand]-decorated). -->
                        <TextBlock Text="Tasks:" Margin="0,4,0,2" FontWeight="SemiBold"/>
                        <ItemsControl ItemsSource="{Binding Tasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,2">
                                        <TextBlock Text="(removed)" DockPanel.Dock="Right"
                                                   Foreground="Red" VerticalAlignment="Center"
                                                   Margin="4,0,0,0"
                                                   Visibility="{Binding IsRemoved,
                                                       Converter={StaticResource BoolToVisibleConverter}}"/>
                                        <!-- REQ-04: soft-delete TASK only, NOT the request -->
                                        <Button Content="Remove" DockPanel.Dock="Right"
                                                Margin="4,0,0,0"
                                                Command="{Binding RemoveTaskCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="Down" DockPanel.Dock="Right"
                                                Margin="4,0,0,0"
                                                Command="{Binding MoveDownCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="Up" DockPanel.Dock="Right"
                                                Margin="4,0,0,0"
                                                Command="{Binding MoveUpCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <TextBox Text="{Binding TaskName, UpdateSourceTrigger=PropertyChanged}"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Add task input row -->
                        <DockPanel Margin="0,8,0,0">
                            <Button Content="Add Task" DockPanel.Dock="Right"
                                    Padding="8,4" Margin="4,0,0,0"
                                    Command="{Binding AddTaskFromBoxCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            <TextBox x:Name="NewTaskBox"/>
                        </DockPanel>

                        <!-- Save / Cancel -->
                        <DockPanel Margin="0,12,0,0">
                            <Button Content="Cancel" DockPanel.Dock="Right"
                                    Padding="8,4" Margin="4,0,0,0"
                                    Command="{Binding DataContext.CancelEditorCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            <Button Content="Save" Padding="16,4"
                                    HorizontalAlignment="Left"
                                    Command="{Binding SaveCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </DockPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Border>
    </Grid>
</UserControl>
