<UserControl x:Class="TimesheetApp.Views.Tabs.BacklogsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:TimesheetApp.Views.Controls"
             xmlns:beh="clr-namespace:TimesheetApp.Views.Behaviors">
    <UserControl.Resources>
        <!-- Lets the TEAM DataGridColumn (outside the visual tree) bind to the VM so it can hide itself
             when only one team is selected — same pattern as the Task List tab. -->
        <ctrl:BindingProxy x:Key="VmProxy" Data="{Binding}"/>
    </UserControl.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- REQ-01: live search + structured filters (all in-memory) + New backlog. -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <DockPanel Margin="0,0,0,6">
                <Button Content="&#10133; New backlog" Command="{Binding BeginCreateCommand}"
                        DockPanel.Dock="Right" Padding="12,5" Margin="6,0,0,0"/>
                <!-- Placeholder lives INSIDE the box (design) instead of an external "Search:" label. -->
                <Grid>
                    <TextBox x:Name="SearchBox" Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Filter by backlog code or project (live)"/>
                    <TextBlock Text="Search code or project…" Foreground="{StaticResource Disabled}"
                               Margin="10,0" VerticalAlignment="Center" IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </DockPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Project:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox Width="110" ItemsSource="{Binding ProjectOptions}" SelectedItem="{Binding FilterProject}"/>
                <TextBlock Text="Type:" VerticalAlignment="Center" Margin="14,0,4,0"/>
                <ComboBox Width="120" ItemsSource="{Binding TypeOptions}" SelectedItem="{Binding FilterType}"/>
                <TextBlock Text="Assignee:" VerticalAlignment="Center" Margin="14,0,4,0"/>
                <ComboBox Width="130" ItemsSource="{Binding AssigneeOptions}" SelectedItem="{Binding FilterAssignee}"/>
                <TextBlock Text="Month:" VerticalAlignment="Center" Margin="14,0,4,0"/>
                <ComboBox Width="100" ItemsSource="{Binding MonthOptions}" SelectedItem="{Binding FilterMonth}"/>
                <!-- P10 (TM-07): multi-team checkbox filter (hidden for single-team users). -->
                <ctrl:TeamFilter DataContext="{Binding TeamFilter}" Margin="14,0,0,0"
                                 VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>

        <!-- REQ-01: backlog list. NOTE: NO delete-backlog button anywhere (REQ-04). -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding Backlogs}" AutoGenerateColumns="False"
                  IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns>
                <!-- Star-width + MinWidth: columns fill a wide window, clamp + scroll when narrow (responsive). -->
                <DataGridTextColumn Header="CODE" Binding="{Binding BacklogCode}" Width="1.6*" MinWidth="120"/>
                <DataGridTextColumn Header="PROJECT" Binding="{Binding Project}" Width="1.2*" MinWidth="96"/>
                <DataGridTextColumn Header="MONTH" Binding="{Binding PeriodMonth}" Width="80" MinWidth="72"/>
                <!-- Type as a teal pill (matches the design's type badge) -->
                <DataGridTemplateColumn Header="TYPE" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource AccentSoft}" CornerRadius="9" Padding="8,2"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Visibility="{Binding Type, Converter={StaticResource NullToCollapsedConverter}}">
                                <TextBlock Text="{Binding Type}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource Accent}"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="ASSIGNEE" Binding="{Binding AssigneeName}" Width="1.2*" MinWidth="110"/>
                <!-- P10 (TM-07): team chip, shown only when >1 team is checked (ShowTeam). The whole column
                     hides for single-team users (via VmProxy) so it isn't an empty 110px gap. -->
                <DataGridTemplateColumn Header="TEAM" Width="110"
                    Visibility="{Binding Data.TeamFilter.ShowTeamColumn, Source={StaticResource VmProxy},
                                 Converter={StaticResource BoolToVisibleConverter}}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource AccentSoft}" CornerRadius="9" Padding="8,2"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Visibility="{Binding ShowTeam, Converter={StaticResource BoolToVisibleConverter}}">
                                <TextBlock Text="{Binding TeamName}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource Accent}"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="TASKS" Binding="{Binding TaskCount}" Width="64"/>
                <DataGridTemplateColumn Header="" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <!-- REQ-03: edit only — no Backlog delete affordance (REQ-04) -->
                            <Button Content="Edit" Style="{StaticResource MiniGhostButton}"
                                    HorizontalAlignment="Right" Margin="0,0,6,0"
                                    Command="{Binding DataContext.BeginEditCommand,
                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding Id}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- REQ-02/03: editor overlay — shown when Editor != null -->
        <Border Grid.RowSpan="2" Background="#66000000"
                Visibility="{Binding Editor, Converter={StaticResource NullToCollapsedConverter}}">
            <Border Width="540" MaxHeight="660" Background="{StaticResource Surface}"
                    CornerRadius="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="#0F172A" Opacity="0.28" BlurRadius="28" ShadowDepth="4" Direction="270"/>
                </Border.Effect>

                <DockPanel DataContext="{Binding Editor}">

                    <!-- Header strip: title switches on create vs edit -->
                    <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBg}"
                            CornerRadius="12,12,0,0" Padding="20,15"
                            BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                        <TextBlock FontWeight="Bold" FontSize="17" Foreground="{StaticResource TextPrimary}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="New backlog"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Text" Value="Edit backlog"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <!-- Footer actions (always visible): error message + Cancel/Save -->
                    <Border DockPanel.Dock="Bottom" Background="{StaticResource HeaderBg}"
                            CornerRadius="0,0,12,12" Padding="20,12"
                            BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
                        <DockPanel>
                            <Button Content="Save" DockPanel.Dock="Right" Padding="22,6"
                                    Command="{Binding SaveCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            <Button Content="Cancel" DockPanel.Dock="Right"
                                    Style="{StaticResource GhostButton}" Padding="18,6" Margin="0,0,8,0"
                                    Command="{Binding DataContext.CancelEditorCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Danger}"
                                       FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap"
                                       Margin="0,0,8,0"
                                       Visibility="{Binding ErrorMessage,
                                           Converter={StaticResource NullToCollapsedConverter}}"/>
                        </DockPanel>
                    </Border>

                    <!-- Scrollable body -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                        <StackPanel>

                            <TextBlock Text="Code" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding BacklogCode, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="Project" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding Projects}" SelectedItem="{Binding Project}"
                                      Margin="0,0,0,10"/>

                            <!-- v4: who is responsible for this ticket -->
                            <TextBlock Text="Assignee" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedAssignee}"
                                      DisplayMemberPath="Name" Margin="0,0,0,10"/>

                            <!-- v2: ticket month (required: month + year) + type -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Month *" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox Width="70" ItemsSource="{Binding Months}"
                                              SelectedItem="{Binding PeriodMonthNumber}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Year *" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox Width="86" ItemsSource="{Binding Years}"
                                              SelectedItem="{Binding PeriodYear}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Type" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox ItemsSource="{Binding Types}" SelectedItem="{Binding Type}"/>
                                </StackPanel>
                            </Grid>

                            <!-- v2: ticket start / end date. Operational fields → shown on CREATE, hidden on
                                 EDIT (edited inline in the Task List, mirroring the deadlines below). -->
                            <Grid Margin="0,0,0,10">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Start date" Style="{StaticResource FieldLabel}"/>
                                    <DatePicker SelectedDate="{Binding StartDate, Converter={StaticResource DateOnly}}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="End date" Style="{StaticResource FieldLabel}"/>
                                    <DatePicker SelectedDate="{Binding EndDate, Converter={StaticResource DateOnly}}"/>
                                </StackPanel>
                            </Grid>

                            <!-- v7: Task List tracking (spec §5.2). DEFAULT backlog never reaches this
                                 editor (it has no Edit affordance), so no extra guard is needed here. -->
                            <Border Background="{StaticResource HeaderBg}" CornerRadius="8" Padding="12,10"
                                    Margin="0,2,0,12">
                                <StackPanel>
                                    <TextBlock Text="Tracking" Style="{StaticResource FieldLabel}"
                                               FontWeight="Bold" Margin="0,0,0,8"/>

                                    <!-- dual deadlines — operational fields: hidden on EDIT, shown on create -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Internal deadline (PCT)" Style="{StaticResource FieldLabel}"/>
                                            <DatePicker SelectedDate="{Binding DeadlineInternal, Converter={StaticResource DateOnly}}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="External deadline (PCA)" Style="{StaticResource FieldLabel}"/>
                                            <DatePicker SelectedDate="{Binding DeadlineExternal, Converter={StaticResource DateOnly}}"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- dual estimates (hours) -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Rough estimate (hours)" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Text="{Binding RoughEstimateText, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Official estimate (hours)" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Text="{Binding OfficialEstimateText, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- manual progress % + PCA contact. Columns symmetric (* | 16 | *) to
                                         match the deadline/estimate rows above; Progress box width-capped so
                                         it reads as a normal field, not an outlier. Both are operational:
                                         on CREATE Progress shows but is disabled; PCA shows + is fillable.
                                         On EDIT both collapse. -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="Progress %" Style="{StaticResource FieldLabel}"/>
                                            <!-- Progress is read-only data (computed elsewhere): disabled on the
                                                 create form so it can't be filled. -->
                                            <TextBox MaxWidth="120" HorizontalAlignment="Left" IsEnabled="False"
                                                     Text="{Binding ProgressText, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="PCA contact" Style="{StaticResource FieldLabel}"/>
                                            <!-- Type-to-filter PCA picker (beh:ComboBoxSearch). -->
                                            <ComboBox ItemsSource="{Binding PcaContacts}"
                                                      SelectedItem="{Binding SelectedPcaContact}"
                                                      DisplayMemberPath="Name" TextSearch.TextPath="Name"
                                                      beh:ComboBoxSearch.Enabled="True"
                                                      ToolTip="Gõ để lọc nhanh danh sách PCA"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- free-text note -->
                                    <TextBlock Text="Note" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="48"
                                             VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"/>

                                    <!-- tag multi-select: dropdown ("Tags (N) ▾") of checkable chips.
                                         Operational field → shown on CREATE, hidden on EDIT (edited inline
                                         in the Task List). Save path (CheckedTagIds) is unchanged. -->
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="Tags" Style="{StaticResource FieldLabel}"/>
                                        <ctrl:TagPicker ItemsSource="{Binding TagPicks}" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- REQ-02: template picker — selecting a template auto-appends its tasks below -->
                            <TextBlock Text="Add a template" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding TemplateNames}"
                                      SelectedItem="{Binding SelectedTemplateName}" Margin="0,0,0,2"/>
                            <TextBlock Text="Selecting a template adds its tasks to the list below."
                                       Foreground="{StaticResource TextSecondary}" FontSize="11"
                                       Margin="0,0,0,12"/>

                            <!-- REQ-02/04: ordered editable task list with reorder + remove-task.
                                 Remove/Up/Down commands live on the UserControl code-behind. -->
                            <TextBlock Text="Tasks" Style="{StaticResource FieldLabel}"/>
                            <ItemsControl ItemsSource="{Binding Tasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource Surface}"
                                                BorderBrush="{StaticResource Border}" BorderThickness="1"
                                                CornerRadius="6" Padding="6,4" Margin="0,0,0,5">
                                            <DockPanel>
                                                <!-- REQ-04: soft-delete TASK only, NOT the backlog -->
                                                <Button Content="&#10005;" DockPanel.Dock="Right"
                                                        Style="{StaticResource TaskIconButton}"
                                                        Foreground="{StaticResource Danger}" ToolTip="Remove task"
                                                        Command="{Binding RemoveTaskCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="&#9660;" DockPanel.Dock="Right"
                                                        Style="{StaticResource TaskIconButton}" ToolTip="Move down"
                                                        Command="{Binding MoveDownCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="&#9650;" DockPanel.Dock="Right"
                                                        Style="{StaticResource TaskIconButton}" ToolTip="Move up"
                                                        Command="{Binding MoveUpCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Border DockPanel.Dock="Right" Background="{StaticResource Danger}"
                                                        CornerRadius="4" Padding="6,1" Margin="6,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding IsRemoved,
                                                            Converter={StaticResource BoolToVisibleConverter}}">
                                                    <TextBlock Text="removed" Foreground="White" FontSize="11"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                                <TextBox Text="{Binding TaskName, UpdateSourceTrigger=PropertyChanged}"
                                                         BorderThickness="0" Background="Transparent"
                                                         VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Add task: opens a dedicated input dialog (no inline text box). -->
                            <Button Content="&#10133; Add task" HorizontalAlignment="Left" Margin="0,4,0,0"
                                    Style="{StaticResource GhostButton}" Padding="14,6"
                                    Command="{Binding AddTaskFromBoxCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"/>

                            <!-- v2: change history (start/end/month/type) — only shown when present -->
                            <StackPanel Margin="0,16,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AuditEntries.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="Change history" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                <ItemsControl ItemsSource="{Binding AuditEntries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                                                    Padding="0,4">
                                                <StackPanel>
                                                    <TextBlock FontSize="12">
                                                        <Run Text="{Binding Field, Mode=OneWay}" FontWeight="SemiBold"/>
                                                        <Run Text=": "/>
                                                        <Run Text="{Binding OldValue, Mode=OneWay, TargetNullValue='—'}"/>
                                                        <Run Text=" &#8594; "/>
                                                        <Run Text="{Binding NewValue, Mode=OneWay, TargetNullValue='—'}"/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}">
                                                        <Run Text="{Binding ChangedByName, Mode=OneWay, TargetNullValue='(?)'}"/>
                                                        <Run Text=" &#183; "/>
                                                        <Run Text="{Binding ChangedAt, Mode=OneWay, StringFormat='dd/MM/yyyy HH:mm'}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
