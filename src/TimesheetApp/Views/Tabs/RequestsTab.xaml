<UserControl x:Class="TimesheetApp.Views.Tabs.RequestsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- REQ-01: live search + structured filters (all in-memory) + New request. -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <DockPanel Margin="0,0,0,6">
                <Button Content="&#10133; New request" Command="{Binding BeginCreateCommand}"
                        DockPanel.Dock="Right" Padding="12,5" Margin="6,0,0,0"/>
                <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Filter by request code or project (live)"/>
            </DockPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Project:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox Width="110" ItemsSource="{Binding ProjectOptions}" SelectedItem="{Binding FilterProject}"/>
                <TextBlock Text="Status:" VerticalAlignment="Center" Margin="14,0,4,0"/>
                <ComboBox Width="120" ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding FilterStatus}"/>
                <TextBlock Text="Assignee:" VerticalAlignment="Center" Margin="14,0,4,0"/>
                <ComboBox Width="130" ItemsSource="{Binding AssigneeOptions}" SelectedItem="{Binding FilterAssignee}"/>
                <TextBlock Text="Month:" VerticalAlignment="Center" Margin="14,0,4,0"/>
                <ComboBox Width="100" ItemsSource="{Binding MonthOptions}" SelectedItem="{Binding FilterMonth}"/>
            </StackPanel>
        </StackPanel>

        <!-- REQ-01: request list. NOTE: NO delete-request button anywhere (REQ-04). -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding Requests}" AutoGenerateColumns="False"
                  IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Code" Binding="{Binding RequestCode}" Width="1.6*"/>
                <DataGridTextColumn Header="Project" Binding="{Binding Project}" Width="1.2*"/>
                <DataGridTextColumn Header="Month" Binding="{Binding PeriodMonth}" Width="80"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Assignee" Binding="{Binding AssigneeName}" Width="1.2*"/>
                <DataGridTextColumn Header="Tasks" Binding="{Binding TaskCount}" Width="64"/>
                <DataGridTemplateColumn Header="" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <!-- REQ-03: edit only — no Request delete affordance (REQ-04) -->
                            <Button Content="Edit" Style="{StaticResource MiniGhostButton}"
                                    HorizontalAlignment="Right" Margin="0,0,6,0"
                                    Command="{Binding DataContext.BeginEditCommand,
                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding Id}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- REQ-02/03: editor overlay — shown when Editor != null -->
        <Border Grid.RowSpan="2" Background="#66000000"
                Visibility="{Binding Editor, Converter={StaticResource NullToCollapsedConverter}}">
            <Border Width="540" MaxHeight="660" Background="{StaticResource Surface}"
                    CornerRadius="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="#0F172A" Opacity="0.28" BlurRadius="28" ShadowDepth="4" Direction="270"/>
                </Border.Effect>

                <DockPanel DataContext="{Binding Editor}">

                    <!-- Header strip: title switches on create vs edit -->
                    <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBg}"
                            CornerRadius="12,12,0,0" Padding="20,15"
                            BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                        <TextBlock FontWeight="Bold" FontSize="17" Foreground="{StaticResource TextPrimary}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="New request"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Text" Value="Edit request"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <!-- Footer actions (always visible): error message + Cancel/Save -->
                    <Border DockPanel.Dock="Bottom" Background="{StaticResource HeaderBg}"
                            CornerRadius="0,0,12,12" Padding="20,12"
                            BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
                        <DockPanel>
                            <Button Content="Save" DockPanel.Dock="Right" Padding="22,6"
                                    Command="{Binding SaveCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            <Button Content="Cancel" DockPanel.Dock="Right"
                                    Style="{StaticResource GhostButton}" Padding="18,6" Margin="0,0,8,0"
                                    Command="{Binding DataContext.CancelEditorCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Danger}"
                                       FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap"
                                       Margin="0,0,8,0"
                                       Visibility="{Binding ErrorMessage,
                                           Converter={StaticResource NullToCollapsedConverter}}"/>
                        </DockPanel>
                    </Border>

                    <!-- Scrollable body -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                        <StackPanel>

                            <TextBlock Text="Code" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding RequestCode, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="Project" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding Projects}" SelectedItem="{Binding Project}"
                                      Margin="0,0,0,10"/>

                            <!-- v4: who is responsible for this ticket -->
                            <TextBlock Text="Assignee" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedAssignee}"
                                      DisplayMemberPath="Name" Margin="0,0,0,10"/>

                            <!-- v2: ticket month (required: month + year) + status -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Month *" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox Width="70" ItemsSource="{Binding Months}"
                                              SelectedItem="{Binding PeriodMonthNumber}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Year *" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox Width="86" ItemsSource="{Binding Years}"
                                              SelectedItem="{Binding PeriodYear}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Status" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox ItemsSource="{Binding Statuses}" SelectedItem="{Binding Status}"/>
                                </StackPanel>
                            </Grid>

                            <!-- v2: ticket start / end date -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Start date" Style="{StaticResource FieldLabel}"/>
                                    <DatePicker SelectedDate="{Binding StartDate, Converter={StaticResource DateOnly}}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="End date" Style="{StaticResource FieldLabel}"/>
                                    <DatePicker SelectedDate="{Binding EndDate, Converter={StaticResource DateOnly}}"/>
                                </StackPanel>
                            </Grid>

                            <!-- REQ-02: template picker — selecting a template auto-appends its tasks below -->
                            <TextBlock Text="Add a template" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding TemplateNames}"
                                      SelectedItem="{Binding SelectedTemplateName}" Margin="0,0,0,2"/>
                            <TextBlock Text="Selecting a template adds its tasks to the list below."
                                       Foreground="{StaticResource TextSecondary}" FontSize="11"
                                       Margin="0,0,0,12"/>

                            <!-- REQ-02/04: ordered editable task list with reorder + remove-task.
                                 Remove/Up/Down commands live on the UserControl code-behind. -->
                            <TextBlock Text="Tasks" Style="{StaticResource FieldLabel}"/>
                            <ItemsControl ItemsSource="{Binding Tasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource Surface}"
                                                BorderBrush="{StaticResource Border}" BorderThickness="1"
                                                CornerRadius="6" Padding="6,4" Margin="0,0,0,5">
                                            <DockPanel>
                                                <!-- REQ-04: soft-delete TASK only, NOT the request -->
                                                <Button Content="&#10005;" DockPanel.Dock="Right"
                                                        Style="{StaticResource TaskIconButton}"
                                                        Foreground="{StaticResource Danger}" ToolTip="Remove task"
                                                        Command="{Binding RemoveTaskCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="&#9660;" DockPanel.Dock="Right"
                                                        Style="{StaticResource TaskIconButton}" ToolTip="Move down"
                                                        Command="{Binding MoveDownCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="&#9650;" DockPanel.Dock="Right"
                                                        Style="{StaticResource TaskIconButton}" ToolTip="Move up"
                                                        Command="{Binding MoveUpCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Border DockPanel.Dock="Right" Background="{StaticResource Danger}"
                                                        CornerRadius="4" Padding="6,1" Margin="6,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding IsRemoved,
                                                            Converter={StaticResource BoolToVisibleConverter}}">
                                                    <TextBlock Text="removed" Foreground="White" FontSize="11"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                                <TextBox Text="{Binding TaskName, UpdateSourceTrigger=PropertyChanged}"
                                                         BorderThickness="0" Background="Transparent"
                                                         VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Add task: opens a dedicated input dialog (no inline text box). -->
                            <Button Content="&#10133; Add task" HorizontalAlignment="Left" Margin="0,4,0,0"
                                    Style="{StaticResource GhostButton}" Padding="14,6"
                                    Command="{Binding AddTaskFromBoxCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"/>

                            <!-- v2: change history (start/end/month/status) — only shown when present -->
                            <StackPanel Margin="0,16,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AuditEntries.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="Change history" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                <ItemsControl ItemsSource="{Binding AuditEntries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                                                    Padding="0,4">
                                                <StackPanel>
                                                    <TextBlock FontSize="12">
                                                        <Run Text="{Binding Field, Mode=OneWay}" FontWeight="SemiBold"/>
                                                        <Run Text=": "/>
                                                        <Run Text="{Binding OldValue, Mode=OneWay, TargetNullValue='—'}"/>
                                                        <Run Text=" &#8594; "/>
                                                        <Run Text="{Binding NewValue, Mode=OneWay, TargetNullValue='—'}"/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}">
                                                        <Run Text="{Binding ChangedByName, Mode=OneWay, TargetNullValue='(?)'}"/>
                                                        <Run Text=" &#183; "/>
                                                        <Run Text="{Binding ChangedAt, Mode=OneWay, StringFormat='dd/MM/yyyy HH:mm'}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
