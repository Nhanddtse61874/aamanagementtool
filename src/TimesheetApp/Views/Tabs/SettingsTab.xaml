<UserControl x:Class="TimesheetApp.Views.Tabs.SettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <ScrollViewer>
            <StackPanel Margin="16">

                <!-- SET-01: DB path + Browse -->
                <TextBlock Text="Database file" Style="{StaticResource SectionTitle}"/>
                <TextBlock Text="Path to the SQLite database file (.db) used to store data."
                           Style="{StaticResource FieldHint}"/>
                <TextBlock Text="Database path" Style="{StaticResource FieldLabel}"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBox Width="420" Height="32" Text="{Binding DbPath, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Browse…" Height="32" Margin="8,0,0,0" Click="OnBrowse"
                            Style="{StaticResource GhostButton}"/>
                    <Button Content="Apply" Height="32" Margin="8,0,0,0" Command="{Binding ApplyDbPathCommand}"/>
                </StackPanel>

                <!-- SET-05: Daily report archive folder -->
                <TextBlock Text="Daily report archive" Style="{StaticResource SectionTitle}"/>
                <TextBlock Text="Folder where weekly daily-report markdown files are exported. Leave empty to use the default (next to the database file)."
                           Style="{StaticResource FieldHint}"/>
                <TextBlock Text="Archive folder" Style="{StaticResource FieldLabel}"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBox Width="420" Height="32" Text="{Binding ArchivePath, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Browse…" Height="32" Margin="8,0,0,0" Click="OnBrowseArchive"
                            Style="{StaticResource GhostButton}"/>
                    <Button Content="Apply" Height="32" Margin="8,0,0,0" Command="{Binding ApplyArchivePathCommand}"/>
                </StackPanel>

                <!-- EX-01/06: Export logs — two mirrored export roots + manual "Export now" -->
                <TextBlock Text="Export logs" Style="{StaticResource SectionTitle}"/>
                <TextBlock Text="Two folders the structured per-team export mirrors to (a shared/SharePoint folder and a local folder). Leave a folder empty to skip it; both empty falls back to the legacy flat archive."
                           Style="{StaticResource FieldHint}"/>
                <TextBlock Text="Shared/SharePoint folder" Style="{StaticResource FieldLabel}"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBox Width="420" Height="32" Text="{Binding ExportRoot1Path, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Browse…" Height="32" Margin="8,0,0,0" Click="OnBrowseExportRoot1"
                            Style="{StaticResource GhostButton}"/>
                    <Button Content="Apply" Height="32" Margin="8,0,0,0" Command="{Binding ApplyExportRoot1Command}"/>
                </StackPanel>
                <TextBlock Text="Local folder" Style="{StaticResource FieldLabel}"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBox Width="420" Height="32" Text="{Binding ExportRoot2Path, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Browse…" Height="32" Margin="8,0,0,0" Click="OnBrowseExportRoot2"
                            Style="{StaticResource GhostButton}"/>
                    <Button Content="Apply" Height="32" Margin="8,0,0,0" Command="{Binding ApplyExportRoot2Command}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="Export now" Height="32" Command="{Binding ExportNowCommand}"/>
                </StackPanel>
                <TextBlock Text="{Binding ExportStatus}" Foreground="{StaticResource TextSecondary}"
                           Margin="0,0,0,16" TextWrapping="Wrap"/>

                <!-- BK-01..07: Backup & Restore -->
                <TextBlock Text="Backup &amp; Restore" Style="{StaticResource SectionTitle}"/>
                <TextBlock Text="Back up the full database to a local folder (ideally outside OneDrive). Restore replaces the current database — restart the app afterwards."
                           Style="{StaticResource FieldHint}"/>
                <TextBlock Text="Backup folder" Style="{StaticResource FieldLabel}"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBox Width="420" Height="32" Text="{Binding BackupFolder, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Browse…" Height="32" Margin="8,0,0,0" Click="OnBrowseBackupFolder"
                            Style="{StaticResource GhostButton}"/>
                    <Button Content="Apply" Height="32" Margin="8,0,0,0" Command="{Binding ApplyBackupSettingsCommand}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                    <CheckBox Content="Auto-backup once per day on startup" VerticalAlignment="Center"
                              IsChecked="{Binding AutoBackupEnabled}"/>
                    <TextBlock Text="Keep last" VerticalAlignment="Center" Margin="20,0,6,0"
                               Foreground="{StaticResource TextSecondary}"/>
                    <TextBox Width="56" Height="32" VerticalContentAlignment="Center"
                             Text="{Binding BackupKeepCount, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="backups" VerticalAlignment="Center" Margin="6,0,0,0"
                               Foreground="{StaticResource TextSecondary}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="Backup now" Height="32" Command="{Binding BackupNowCommand}"
                            IsEnabled="{Binding HasBackupFolder}"/>
                    <Button Content="Refresh" Height="32" Margin="8,0,0,0" Style="{StaticResource GhostButton}"
                            Command="{Binding RefreshBackupsCommand}" IsEnabled="{Binding HasBackupFolder}"/>
                </StackPanel>
                <TextBlock Text="{Binding BackupStatus}" Foreground="{StaticResource TextSecondary}"
                           Margin="0,0,0,6" TextWrapping="Wrap"/>
                <ItemsControl ItemsSource="{Binding Backups}" Margin="0,0,0,16">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6"
                                    Margin="0,0,0,5" Padding="10,6">
                                <DockPanel>
                                    <Button Content="Restore" DockPanel.Dock="Right" Margin="4,0,0,0"
                                            Style="{StaticResource DangerGhostButton}"
                                            Click="OnRestoreBackup"
                                            CommandParameter="{Binding}"/>
                                    <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0"
                                               Foreground="{StaticResource TextSecondary}" FontSize="12"
                                               Text="{Binding SizeBytes, StringFormat={}{0:N0} bytes}"/>
                                    <TextBlock VerticalAlignment="Center" FontWeight="SemiBold"
                                               Text="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm:ss}"/>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- RT-01..07: Data retention (DESTRUCTIVE) — off by default; manual run + dry-run -->
                <TextBlock Text="Data retention" Style="{StaticResource SectionTitle}"/>
                <TextBlock Text="When enabled, business data older than the recent N-month window is archived (per-team markdown + a verified database snapshot) and then deleted from the live database. Needs an export root configured. Default off. Preview is read-only; Run now permanently deletes data."
                           Style="{StaticResource FieldHint}"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                    <CheckBox Content="Enable retention" VerticalAlignment="Center"
                              IsChecked="{Binding RetentionEnabled}"/>
                    <TextBlock Text="Keep last" VerticalAlignment="Center" Margin="20,0,6,0"
                               Foreground="{StaticResource TextSecondary}"/>
                    <TextBox Width="56" Height="32" VerticalContentAlignment="Center"
                             Text="{Binding RetentionMonths, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="months" VerticalAlignment="Center" Margin="6,0,0,0"
                               Foreground="{StaticResource TextSecondary}"/>
                    <Button Content="Apply" Height="32" Margin="20,0,0,0"
                            Command="{Binding ApplyRetentionSettingsCommand}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="Preview" Height="32" Style="{StaticResource GhostButton}"
                            Command="{Binding PreviewRetentionCommand}"/>
                    <Button Content="Run retention now" Height="32" Margin="8,0,0,0"
                            Style="{StaticResource DangerGhostButton}" Click="OnRunRetention"/>
                </StackPanel>
                <TextBlock Text="{Binding RetentionStatus}" Foreground="{StaticResource TextSecondary}"
                           Margin="0,0,0,6" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding RetentionPreviewText}" Foreground="{StaticResource TextSecondary}"
                           FontFamily="Consolas" FontSize="12" Margin="0,0,0,16" TextWrapping="Wrap"/>

                <!-- SET-02: N-days warning (default 3) -->
                <TextBlock Text="&quot;Not logged&quot; warning window" Style="{StaticResource SectionTitle}"/>
                <TextBlock Text="Warn if no hours are logged within this many recent working days."
                           Style="{StaticResource FieldHint}"/>
                <TextBlock Text="Working days" Style="{StaticResource FieldLabel}"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBox Width="60" Height="32" Text="{Binding WarningDays, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Save" Height="32" Margin="8,0,0,0" Command="{Binding SaveWarningDaysCommand}"/>
                </StackPanel>

                <!-- SET-03: Task templates — grouped list + New template button.
                     Each template = the set of task rows sharing one name; edited via the overlay. -->
                <TextBlock Text="Task templates" Style="{StaticResource SectionTitle}"/>
                <TextBlock Text="Each template has a name and several tasks. Use a template to quickly create a request's task list."
                           Style="{StaticResource FieldHint}"/>
                <Button Content="&#10133; New template" HorizontalAlignment="Left"
                        Command="{Binding BeginCreateTemplateCommand}" Margin="0,0,0,6"/>
                <ItemsControl ItemsSource="{Binding TemplateGroups}" Margin="0,0,0,16">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6"
                                    Margin="0,0,0,5" Padding="10,6">
                                <DockPanel>
                                    <Button Content="Delete" DockPanel.Dock="Right" Margin="4,0,0,0"
                                            Style="{StaticResource DangerGhostButton}"
                                            Command="{Binding DataContext.DeleteTemplateCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding Name}"/>
                                    <Button Content="Edit" DockPanel.Dock="Right" Margin="4,0,0,0"
                                            Style="{StaticResource MiniGhostButton}"
                                            Command="{Binding DataContext.BeginEditTemplateCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding Name}"/>
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <Run Text="("/><Run Text="{Binding TaskCount}"/><Run Text=" task)"/>
                                    </TextBlock>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- SET-04: DefaultTasks sync -->
                <TextBlock Text="Default tasks" Style="{StaticResource SectionTitle}"/>
                <TextBlock Text="Sync the default-task list into the default request."
                           Style="{StaticResource FieldHint}"/>
                <Button Content="Sync default tasks" HorizontalAlignment="Left"
                        Style="{StaticResource GhostButton}" Command="{Binding SaveDefaultTasksCommand}"/>

                <!-- TAG-01: custom tags (icon + color + text), edited via the overlay -->
                <TextBlock Text="Tags" Style="{StaticResource SectionTitle}" Margin="0,20,0,0"/>
                <TextBlock Text="Custom labels (icon + color) you can attach to backlogs on the Task List."
                           Style="{StaticResource FieldHint}"/>
                <Button Content="&#10133; New tag" HorizontalAlignment="Left"
                        Command="{Binding BeginCreateTagCommand}" Margin="0,0,0,6"/>
                <ItemsControl ItemsSource="{Binding Tags}" Margin="0,0,0,16">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6"
                                    Margin="0,0,0,5" Padding="10,6">
                                <DockPanel>
                                    <Button Content="Delete" DockPanel.Dock="Right" Margin="4,0,0,0"
                                            Style="{StaticResource DangerGhostButton}"
                                            Command="{Binding DataContext.DeleteTagCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding Id}"/>
                                    <Button Content="Edit" DockPanel.Dock="Right" Margin="4,0,0,0"
                                            Style="{StaticResource MiniGhostButton}"
                                            Command="{Binding DataContext.BeginEditTagCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                    <!-- live tag chip: color via HexToBrushConverter + icon glyph + text -->
                                    <Border CornerRadius="10" Padding="9,2" HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Background="{Binding Color, Converter={StaticResource HexToBrush}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Icon}" Margin="0,0,5,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Text}" FontWeight="SemiBold"
                                                       Foreground="White" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- TL-11: PCA contacts (soft-delete, mirrors Users) -->
                <TextBlock Text="PCA contacts" Style="{StaticResource SectionTitle}"/>
                <TextBlock Text="External (PCA) contacts you can assign to a backlog. Deactivating keeps historical references."
                           Style="{StaticResource FieldHint}"/>
                <DockPanel Margin="0,0,0,6">
                    <Button Content="&#10133; Add contact" DockPanel.Dock="Right" Margin="6,0,0,0"
                            Command="{Binding AddPcaContactCommand}"/>
                    <TextBox Width="260" HorizontalAlignment="Left"
                             Text="{Binding NewPcaName, UpdateSourceTrigger=PropertyChanged}"/>
                </DockPanel>
                <ItemsControl ItemsSource="{Binding PcaContacts}" Margin="0,0,0,16">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6"
                                    Margin="0,0,0,5" Padding="10,6">
                                <DockPanel>
                                    <Button Content="Deactivate" DockPanel.Dock="Right" Margin="4,0,0,0"
                                            Style="{StaticResource DangerGhostButton}"
                                            IsEnabled="{Binding IsActive}"
                                            Command="{Binding DataContext.DeactivatePcaContactCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding Id}"/>
                                    <Button Content="Rename" DockPanel.Dock="Right" Margin="4,0,0,0"
                                            Style="{StaticResource MiniGhostButton}"
                                            Command="{Binding DataContext.RenamePcaContactCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding Id}"/>
                                    <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource Disabled}"
                                               Text="Inactive">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalAlignment="Center" IsEnabled="{Binding IsActive}"
                                             BorderThickness="0" Background="Transparent"/>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- TM-03: Teams (soft-delete CRUD, mirrors PCA) + per-team membership overlay -->
                <TextBlock Text="Teams" Style="{StaticResource SectionTitle}"/>
                <TextBlock Text="Top-level teams that scope backlogs, tasks and standup. Deactivating keeps historical references. Use Members to assign users (many-to-many)."
                           Style="{StaticResource FieldHint}"/>
                <DockPanel Margin="0,0,0,6">
                    <Button Content="&#10133; Add team" DockPanel.Dock="Right" Margin="6,0,0,0"
                            Command="{Binding AddTeamCommand}"/>
                    <TextBox Width="260" HorizontalAlignment="Left"
                             Text="{Binding NewTeamName, UpdateSourceTrigger=PropertyChanged}"/>
                </DockPanel>
                <ItemsControl ItemsSource="{Binding Teams}" Margin="0,0,0,16">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6"
                                    Margin="0,0,0,5" Padding="10,6">
                                <DockPanel>
                                    <Button Content="Deactivate" DockPanel.Dock="Right" Margin="4,0,0,0"
                                            Style="{StaticResource DangerGhostButton}"
                                            IsEnabled="{Binding IsActive}"
                                            Command="{Binding DataContext.DeactivateTeamCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding Id}"/>
                                    <Button Content="Members" DockPanel.Dock="Right" Margin="4,0,0,0"
                                            Style="{StaticResource MiniGhostButton}"
                                            IsEnabled="{Binding IsActive}"
                                            Command="{Binding DataContext.BeginEditMembersCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding Id}"/>
                                    <Button Content="Rename" DockPanel.Dock="Right" Margin="4,0,0,0"
                                            Style="{StaticResource MiniGhostButton}"
                                            Command="{Binding DataContext.RenameTeamCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding Id}"/>
                                    <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource Disabled}"
                                               Text="Inactive">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalAlignment="Center" IsEnabled="{Binding IsActive}"
                                             BorderThickness="0" Background="Transparent"/>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- HOL-01: holiday calendar — a 7-col month grid; click a day to toggle a holiday -->
                <TextBlock Text="Holiday calendar" Style="{StaticResource SectionTitle}"/>
                <TextBlock Text="Click a day to mark/unmark it a holiday. Weekends are excluded automatically."
                           Style="{StaticResource FieldHint}"/>
                <Border BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8"
                        Padding="12" Margin="0,0,0,16" HorizontalAlignment="Left" Width="380"
                        DataContext="{Binding HolidayCalendar}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,8">
                            <Button Content="&#9664;" DockPanel.Dock="Left" Style="{StaticResource MiniGhostButton}"
                                    Command="{Binding PrevMonthCommand}"/>
                            <Button Content="&#9654;" DockPanel.Dock="Right" Style="{StaticResource MiniGhostButton}"
                                    Command="{Binding NextMonthCommand}"/>
                            <TextBlock Text="{Binding MonthLabel}" FontWeight="SemiBold" FontSize="14"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DockPanel>
                        <!-- weekday header -->
                        <UniformGrid Columns="7" Margin="0,0,0,4">
                            <TextBlock Text="Mon" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                            <TextBlock Text="Tue" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                            <TextBlock Text="Wed" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                            <TextBlock Text="Thu" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                            <TextBlock Text="Fri" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                            <TextBlock Text="Sat" HorizontalAlignment="Center" Foreground="{StaticResource Disabled}" FontSize="11"/>
                            <TextBlock Text="Sun" HorizontalAlignment="Center" Foreground="{StaticResource Disabled}" FontSize="11"/>
                        </UniformGrid>
                        <ItemsControl ItemsSource="{Binding Days}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="7"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- day cell: distinct styling for holiday / weekend / normal / out-of-month -->
                                    <Button Margin="2" Height="34"
                                            Command="{Binding DataContext.ToggleHolidayCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding Date}"
                                            IsEnabled="{Binding IsInMonth}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="{StaticResource Surface}"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="cell" CornerRadius="6"
                                                                    Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}">
                                                                <TextBlock Text="{Binding DayNumber}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{TemplateBinding Foreground}"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <!-- out-of-month: faint placeholder -->
                                                    <DataTrigger Binding="{Binding IsInMonth}" Value="False">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="Foreground" Value="{StaticResource Disabled}"/>
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                    </DataTrigger>
                                                    <!-- weekend: gray -->
                                                    <DataTrigger Binding="{Binding IsWeekend}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource BadgeGrayBg}"/>
                                                        <Setter Property="Foreground" Value="{StaticResource BadgeGrayFg}"/>
                                                    </DataTrigger>
                                                    <!-- holiday: accent (teal) — wins over weekend -->
                                                    <DataTrigger Binding="{Binding IsHoliday}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource Accent}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- SET-03: template editor overlay — themed card mirroring the Requests editor. -->
        <Border Background="#66000000"
                Visibility="{Binding TemplateEditor,
                             Converter={StaticResource NullToCollapsedConverter}}">
            <Border Width="500" MaxHeight="600" Background="{StaticResource Surface}" CornerRadius="12"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="#0F172A" Opacity="0.28" BlurRadius="28" ShadowDepth="4" Direction="270"/>
                </Border.Effect>
                <DockPanel DataContext="{Binding TemplateEditor}">

                    <!-- Header -->
                    <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBg}" CornerRadius="12,12,0,0"
                            Padding="20,15" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                        <TextBlock Text="Task template" FontWeight="Bold" FontSize="17"
                                   Foreground="{StaticResource TextPrimary}"/>
                    </Border>

                    <!-- Footer -->
                    <Border DockPanel.Dock="Bottom" Background="{StaticResource HeaderBg}" CornerRadius="0,0,12,12"
                            Padding="20,12" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
                        <DockPanel>
                            <Button Content="Save" DockPanel.Dock="Right" Padding="22,6"
                                    Command="{Binding DataContext.SaveTemplateCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            <Button Content="Cancel" DockPanel.Dock="Right" Style="{StaticResource GhostButton}"
                                    Padding="18,6" Margin="0,0,8,0"
                                    Command="{Binding DataContext.CancelTemplateCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            <TextBlock/>
                        </DockPanel>
                    </Border>

                    <!-- Body -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                        <StackPanel>
                            <TextBlock Text="Template name" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding TemplateName, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12"/>

                            <TextBlock Text="Tasks in this template" Style="{StaticResource FieldLabel}"/>
                            <ItemsControl ItemsSource="{Binding Tasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
                                                BorderThickness="1" CornerRadius="6" Padding="6,4" Margin="0,0,0,5">
                                            <DockPanel>
                                                <Button Content="&#10005;" DockPanel.Dock="Right"
                                                        Style="{StaticResource TaskIconButton}"
                                                        Foreground="{StaticResource Danger}" ToolTip="Remove task"
                                                        Command="{Binding RemoveTaskCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="&#9660;" DockPanel.Dock="Right"
                                                        Style="{StaticResource TaskIconButton}" ToolTip="Move down"
                                                        Command="{Binding MoveDownCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="&#9650;" DockPanel.Dock="Right"
                                                        Style="{StaticResource TaskIconButton}" ToolTip="Move up"
                                                        Command="{Binding MoveUpCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <TextBox Text="{Binding TaskName, UpdateSourceTrigger=PropertyChanged}"
                                                         BorderThickness="0" Background="Transparent"
                                                         VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button Content="&#10133; Add task" HorizontalAlignment="Left" Margin="0,4,0,0"
                                    Style="{StaticResource GhostButton}" Padding="14,6"
                                    Command="{Binding AddTaskFromBoxCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Border>

        <!-- TAG-01: tag editor overlay — mirrors the template editor card. -->
        <Border Background="#66000000"
                Visibility="{Binding TagEditor,
                             Converter={StaticResource NullToCollapsedConverter}}">
            <Border Width="460" MaxHeight="600" Background="{StaticResource Surface}" CornerRadius="12"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="#0F172A" Opacity="0.28" BlurRadius="28" ShadowDepth="4" Direction="270"/>
                </Border.Effect>
                <DockPanel DataContext="{Binding TagEditor}">

                    <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBg}" CornerRadius="12,12,0,0"
                            Padding="20,15" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                        <TextBlock Text="Tag" FontWeight="Bold" FontSize="17"
                                   Foreground="{StaticResource TextPrimary}"/>
                    </Border>

                    <Border DockPanel.Dock="Bottom" Background="{StaticResource HeaderBg}" CornerRadius="0,0,12,12"
                            Padding="20,12" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
                        <DockPanel>
                            <Button Content="Save" DockPanel.Dock="Right" Padding="22,6"
                                    Command="{Binding DataContext.SaveTagCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            <Button Content="Cancel" DockPanel.Dock="Right" Style="{StaticResource GhostButton}"
                                    Padding="18,6" Margin="0,0,8,0"
                                    Command="{Binding DataContext.CancelTagCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            <TextBlock/>
                        </DockPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                        <StackPanel>
                            <!-- live preview chip -->
                            <TextBlock Text="Preview" Style="{StaticResource FieldLabel}"/>
                            <Border CornerRadius="10" Padding="10,3" HorizontalAlignment="Left" Margin="0,0,0,14"
                                    Background="{Binding Color, Converter={StaticResource HexToBrush}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Text}" FontWeight="SemiBold" Foreground="White"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Label" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                            <TextBlock Text="Icon (emoji or glyph)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding Icon, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                            <ItemsControl ItemsSource="{Binding IconQuickPicks}" Margin="0,0,0,12">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding}" Width="34" Height="30" Margin="0,0,4,4"
                                                Style="{StaticResource GhostButton}"
                                                Command="{Binding DataContext.PickIconCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Color (hex)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding Color, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                            <ItemsControl ItemsSource="{Binding ColorSwatches}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Width="30" Height="26" Margin="0,0,4,4"
                                                Background="{Binding Converter={StaticResource HexToBrush}}"
                                                Command="{Binding DataContext.PickColorCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border CornerRadius="5" Background="{TemplateBinding Background}"
                                                            BorderBrush="{StaticResource BorderStrong}" BorderThickness="1"/>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Border>

        <!-- TM-03: team membership editor overlay — checkbox list of active users; replace-all save. -->
        <Border Background="#66000000"
                Visibility="{Binding MembershipEditor,
                             Converter={StaticResource NullToCollapsedConverter}}">
            <Border Width="420" MaxHeight="600" Background="{StaticResource Surface}" CornerRadius="12"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="#0F172A" Opacity="0.28" BlurRadius="28" ShadowDepth="4" Direction="270"/>
                </Border.Effect>
                <DockPanel DataContext="{Binding MembershipEditor}">

                    <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBg}" CornerRadius="12,12,0,0"
                            Padding="20,15" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                        <TextBlock FontWeight="Bold" FontSize="17" Foreground="{StaticResource TextPrimary}">
                            <Run Text="Members —"/><Run Text="{Binding TeamName, Mode=OneWay}"/>
                        </TextBlock>
                    </Border>

                    <Border DockPanel.Dock="Bottom" Background="{StaticResource HeaderBg}" CornerRadius="0,0,12,12"
                            Padding="20,12" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
                        <DockPanel>
                            <Button Content="Save" DockPanel.Dock="Right" Padding="22,6"
                                    Command="{Binding DataContext.SaveMembersCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            <Button Content="Cancel" DockPanel.Dock="Right" Style="{StaticResource GhostButton}"
                                    Padding="18,6" Margin="0,0,8,0"
                                    Command="{Binding DataContext.CancelMembersCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            <TextBlock/>
                        </DockPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                        <ItemsControl ItemsSource="{Binding Users}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}" Margin="0,0,0,8"
                                              IsChecked="{Binding IsChecked}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
