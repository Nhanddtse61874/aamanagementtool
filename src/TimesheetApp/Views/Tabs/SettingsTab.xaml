<UserControl x:Class="TimesheetApp.Views.Tabs.SettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <ScrollViewer>
            <StackPanel Margin="16">

                <!-- SET-01: DB path + Browse -->
                <TextBlock Text="Database file" FontWeight="Bold"/>
                <TextBlock Text="Path to the SQLite database file (.db) used to store data."
                           Foreground="Gray" FontSize="11" Margin="0,0,0,2"/>
                <TextBlock Text="Database path:" Margin="0,2,0,0"/>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,12">
                    <TextBox Width="420" Text="{Binding DbPath, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Browse..." Margin="8,0,0,0" Click="OnBrowse"
                            Style="{StaticResource GhostButton}"/>
                    <Button Content="Apply" Margin="8,0,0,0" Command="{Binding ApplyDbPathCommand}"/>
                </StackPanel>

                <!-- SET-02: N-days warning (default 3) -->
                <TextBlock Text="&quot;Not logged&quot; warning window" FontWeight="Bold"/>
                <TextBlock Text="Warn if no hours are logged within this many recent working days."
                           Foreground="Gray" FontSize="11" Margin="0,0,0,2"/>
                <TextBlock Text="Working days:" Margin="0,2,0,0"/>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,12">
                    <TextBox Width="60" Text="{Binding WarningDays, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Save" Margin="8,0,0,0" Command="{Binding SaveWarningDaysCommand}"/>
                </StackPanel>

                <!-- SET-03: Task templates — grouped list + New template button.
                     Each template = the set of task rows sharing one name; edited via the overlay. -->
                <TextBlock Text="Task templates" FontWeight="Bold"/>
                <TextBlock Text="Each template has a name and several tasks. Use a template to quickly create a request's task list."
                           Foreground="Gray" FontSize="11" Margin="0,0,0,4"/>
                <Button Content="➕ New template" HorizontalAlignment="Left"
                        Command="{Binding BeginCreateTemplateCommand}" Margin="0,0,0,4"/>
                <ItemsControl ItemsSource="{Binding TemplateGroups}" Margin="0,0,0,12">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#DDD" BorderThickness="1" Margin="0,2" Padding="8,4">
                                <DockPanel>
                                    <Button Content="Delete" DockPanel.Dock="Right" Margin="4,0,0,0"
                                            Style="{StaticResource DangerButton}"
                                            Command="{Binding DataContext.DeleteTemplateCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding Name}"/>
                                    <Button Content="Edit" DockPanel.Dock="Right" Margin="4,0,0,0"
                                            Style="{StaticResource MiniGhostButton}"
                                            Command="{Binding DataContext.BeginEditTemplateCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding Name}"/>
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <Run Text="("/><Run Text="{Binding TaskCount}"/><Run Text=" task)"/>
                                    </TextBlock>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- SET-04: DefaultTasks sync -->
                <TextBlock Text="Default tasks" FontWeight="Bold"/>
                <TextBlock Text="Sync the default-task list into the default request."
                           Foreground="Gray" FontSize="11" Margin="0,0,0,2"/>
                <Button Content="Sync default tasks" HorizontalAlignment="Left"
                        Style="{StaticResource GhostButton}"
                        Margin="0,4,0,0" Command="{Binding SaveDefaultTasksCommand}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- SET-03: template editor overlay — shown when TemplateEditor != null (mirrors RequestsTab). -->
        <Border Background="#80000000"
                Visibility="{Binding TemplateEditor,
                             Converter={StaticResource NullToCollapsedConverter}}">
            <Border Background="White" Width="480" Padding="16"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxHeight="600">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel DataContext="{Binding TemplateEditor}">
                        <TextBlock Text="Task template" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>

                        <TextBlock Text="Template name:"/>
                        <TextBox Text="{Binding TemplateName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,2,0,8"/>

                        <!-- Editable task-name list with reorder + remove. Remove/Up/Down on the editor
                             VM are plain methods, so they are wrapped as commands on the code-behind. -->
                        <TextBlock Text="Tasks in this template:" FontWeight="SemiBold" Margin="0,4,0,2"/>
                        <ItemsControl ItemsSource="{Binding Tasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,2">
                                        <Button Content="Remove" DockPanel.Dock="Right" Margin="4,0,0,0"
                                                Style="{StaticResource DangerButton}"
                                                Command="{Binding RemoveTaskCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="Down" DockPanel.Dock="Right" Margin="4,0,0,0"
                                                Style="{StaticResource MiniGhostButton}"
                                                Command="{Binding MoveDownCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="Up" DockPanel.Dock="Right" Margin="4,0,0,0"
                                                Style="{StaticResource MiniGhostButton}"
                                                Command="{Binding MoveUpCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <TextBox Text="{Binding TaskName, UpdateSourceTrigger=PropertyChanged}"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Add task input row -->
                        <DockPanel Margin="0,8,0,0">
                            <Button Content="➕ Add task" DockPanel.Dock="Right" Margin="4,0,0,0"
                                    Command="{Binding AddTaskFromBoxCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            <TextBox x:Name="NewTaskBox"/>
                        </DockPanel>

                        <!-- Save / Cancel -->
                        <DockPanel Margin="0,12,0,0">
                            <Button Content="Cancel" DockPanel.Dock="Right" Margin="4,0,0,0"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding DataContext.CancelTemplateCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            <Button Content="Save" HorizontalAlignment="Left"
                                    Command="{Binding DataContext.SaveTemplateCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </DockPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Border>
    </Grid>
</UserControl>
