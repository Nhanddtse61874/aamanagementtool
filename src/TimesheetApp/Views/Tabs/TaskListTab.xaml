<UserControl x:Class="TimesheetApp.Views.Tabs.TaskListTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TimesheetApp.ViewModels"
             xmlns:ctrl="clr-namespace:TimesheetApp.Views.Controls">
  <UserControl.Resources>
    <!-- Local style helpers: show-when-true / show-when-false / collapse-when-true, keyed off a bool
         binding, so this tab needs no new IValueConverter (W3 owns the converter set). -->
    <Style x:Key="ShowWhenTrue" TargetType="FrameworkElement">
      <Setter Property="Visibility" Value="Collapsed"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsGantt}" Value="True">
          <Setter Property="Visibility" Value="Visible"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="ShowWhenGrid" TargetType="FrameworkElement">
      <Setter Property="Visibility" Value="Visible"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsGantt}" Value="True">
          <Setter Property="Visibility" Value="Collapsed"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <!-- Chip template shared by the grid. System chips use fixed amber/red theme brushes; custom tags
         use HexToBrush over the tag's hex color + its icon glyph. -->
    <DataTemplate x:Key="ChipTemplate" DataType="{x:Type vm:TaskListChipVm}">
      <Border CornerRadius="10" Padding="9,2" Margin="0,0,5,0" VerticalAlignment="Center">
        <Border.Style>
          <Style TargetType="Border">
            <!-- default = custom tag: HexToBrush background -->
            <Setter Property="Background" Value="{Binding Color, Converter={StaticResource HexToBrush}}"/>
            <Style.Triggers>
              <!-- system Warning chip = amber -->
              <DataTrigger Binding="{Binding IsSystem}" Value="True">
                <Setter Property="Background" Value="{StaticResource AmberBg}"/>
                <Setter Property="BorderBrush" Value="{StaticResource AmberBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
              </DataTrigger>
              <!-- system Late chip = red -->
              <DataTrigger Binding="{Binding IsLate}" Value="True">
                <Setter Property="Background" Value="{StaticResource Danger}"/>
                <Setter Property="BorderThickness" Value="0"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="{Binding Icon}" Margin="0,0,5,0" VerticalAlignment="Center"
                     FontFamily="Segoe UI Emoji"
                     Visibility="{Binding Icon, Converter={StaticResource NullToCollapsedConverter}}"/>
          <TextBlock Text="{Binding Text}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <!-- custom tag text = white on the tag color -->
                <Setter Property="Foreground" Value="White"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsSystem}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource AmberFg}"/>
                  </DataTrigger>
                  <DataTrigger Binding="{Binding IsLate}" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </StackPanel>
      </Border>
    </DataTemplate>

    <!-- Proxy so the TEAM DataGridColumn (outside the visual tree) can bind to the VM's TeamFilter and
         hide itself when only one team is selected (the cell would otherwise be empty dead space). -->
    <ctrl:BindingProxy x:Key="VmProxy" Data="{Binding}"/>

    <!-- Text-column cells vertically centered so plain-text columns (CODE/PROJECT/LOGGED/ESTIMATE) line up
         with the boxed inline editors (ComboBox/DatePicker are h28 centered; a DataGridTextColumn TextBlock
         is top-aligned by default, which made those columns sit a few px high — the row looked uneven). -->
    <Style x:Key="GridCellText" TargetType="TextBlock">
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
  </UserControl.Resources>

  <DockPanel Margin="12">

    <!-- Controls: month selector + Grid/Gantt toggle + collapse-chart toggle + Export this month. -->
    <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,8">
      <StackPanel Orientation="Horizontal" Margin="0,0,16,6">
        <TextBlock Text="Month:" VerticalAlignment="Center" Margin="0,0,4,0"/>
        <!-- ISSUE 3: month 0 = "All months" (lists every backlog like the Backlog tab); 1-12 filter. -->
        <ComboBox Width="86" ItemsSource="{Binding Months}" SelectedItem="{Binding SelectedMonth}">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock>
                <TextBlock.Style>
                  <Style TargetType="TextBlock">
                    <Setter Property="Text" Value="{Binding}"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding}" Value="0">
                        <Setter Property="Text" Value="All months"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
        <ComboBox Width="86" Margin="6,0,0,0" ItemsSource="{Binding Years}" SelectedItem="{Binding SelectedYear}"/>
        <!-- P10 (TM-07): multi-team checkbox filter (hidden for single-team users). -->
        <ctrl:TeamFilter DataContext="{Binding TeamFilter}" Margin="14,0,0,0" VerticalAlignment="Center"/>
      </StackPanel>

      <!-- Grid↔Gantt segmented control (two themed ToggleButtons; clicks set IsGantt in code-behind,
           IsChecked reflects it — ToolbarGhostToggle gives a clear accent on the active one). -->
      <StackPanel Orientation="Horizontal" Margin="0,0,16,6">
        <ToggleButton x:Name="GridToggle" Content="Grid" IsChecked="True" Click="OnSelectGrid"
                      Padding="14,4" Style="{StaticResource ToolbarGhostToggle}"/>
        <ToggleButton x:Name="GanttToggle" Content="Gantt" Click="OnSelectGantt"
                      Padding="14,4" Style="{StaticResource ToolbarGhostToggle}"/>
      </StackPanel>

      <ToggleButton IsChecked="{Binding IsChartCollapsed}" Padding="14,4" Margin="0,0,16,6"
                    ToolTip="Show / hide the chart area">
        <ToggleButton.Style>
          <Style TargetType="ToggleButton" BasedOn="{StaticResource ToolbarGhostToggle}">
            <Setter Property="Content" Value="Hide chart"/>
            <Style.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter Property="Content" Value="Show chart"/>
              </Trigger>
            </Style.Triggers>
          </Style>
        </ToggleButton.Style>
      </ToggleButton>

      <Button Content="&#11015; Export this month" Command="{Binding ExportThisMonthCommand}"
              Style="{StaticResource ToolbarButton}" Margin="0,0,12,6"
              ToolTip="Write this month's Task List overview to a markdown file"/>
      <TextBlock Text="{Binding ExportStatus}" Foreground="{StaticResource TextSecondary}"
                 VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
    </WrapPanel>

    <!-- Collapsible chart area (Gantt placeholder for Wave 6). Collapses via IsChartCollapsed. -->
    <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBg}"
            BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8"
            MinHeight="120" MaxHeight="320" Margin="0,0,0,10" Padding="12">
      <Border.Style>
        <Style TargetType="Border">
          <Setter Property="Visibility" Value="Visible"/>
          <Style.Triggers>
            <DataTrigger Binding="{Binding IsChartCollapsed}" Value="True">
              <Setter Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <!-- Gantt canvas (shown when IsGantt). Horizontally scrollable; bars are drawn in code-behind
           reading ActualWidth post-layout (R5). When in Grid mode, a hint sits in its place. -->
      <Grid>
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      Style="{StaticResource ShowWhenTrue}">
          <Canvas x:Name="GanttCanvas" Background="Transparent"
                  SizeChanged="OnGanttCanvasSizeChanged"/>
        </ScrollViewer>
        <TextBlock Text="Switch to Gantt to see the timeline." Foreground="{StaticResource TextSecondary}"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource ShowWhenGrid}"/>
      </Grid>
    </Border>

    <!-- GRID view: one row per non-DEFAULT backlog in the selected month, expandable to its tasks. -->
    <DataGrid ItemsSource="{Binding Rows}" AutoGenerateColumns="False" IsReadOnly="True"
              SelectionMode="Single"
              ColumnHeaderHeight="40"
              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
      <!-- BasedOn the theme DataGrid style so it KEEPS RowHeight=36 + alternating rows + gridlines
           (a plain ShowWhenGrid style would replace the theme, dropping RowHeight → rows auto-size and
           balloon vertically on resize). The IsGantt trigger reproduces ShowWhenGrid's hide behavior. -->
      <DataGrid.Style>
        <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
          <Setter Property="Visibility" Value="Visible"/>
          <Style.Triggers>
            <DataTrigger Binding="{Binding IsGantt}" Value="True">
              <Setter Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </DataGrid.Style>
      <DataGrid.Columns>
        <!-- expand toggle for the row-detail (tasks + status). A Button bound to the VM's ToggleExpandCommand
             (the same reliable command pattern as the Backlog tab's Edit button) — the previous in-cell
             ToggleButton's IsChecked write to IsExpanded never reached the row, so nothing ever expanded.
             Chevron points right when collapsed, down when expanded. -->
        <DataGridTemplateColumn Header="" Width="30">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <Button Command="{Binding DataContext.ToggleExpandCommand,
                                RelativeSource={RelativeSource AncestorType=DataGrid}}"
                      CommandParameter="{Binding}" Padding="2" Width="24"
                      ToolTip="Hiện / ẩn danh sách task của backlog này">
                <Button.Style>
                  <Style TargetType="Button" BasedOn="{StaticResource MiniGhostButton}">
                    <Setter Property="Content" Value="&#9654;"/>  <!-- ▶ collapsed -->
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                        <Setter Property="Content" Value="&#9660;"/>  <!-- ▼ expanded -->
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Button.Style>
              </Button>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>

        <!-- Star-width + MinWidth = responsive: columns grow to fill a wide window, clamp to MinWidth and
             trigger horizontal scroll when narrow. Text stays a fixed readable size (no font scaling). -->
        <DataGridTextColumn Header="CODE" Binding="{Binding BacklogCode}" Width="1.3*" MinWidth="112"
                            ElementStyle="{StaticResource GridCellText}"/>
        <DataGridTextColumn Header="PROJECT" Binding="{Binding Project}" Width="*" MinWidth="90"
                            ElementStyle="{StaticResource GridCellText}"/>

        <!-- P10 (TM-07): team chip, shown only when >1 team is checked (ShowTeam). The whole column hides
             for single-team users (via VmProxy) so it doesn't leave an empty 110px gap. -->
        <DataGridTemplateColumn Header="TEAM" Width="110"
            Visibility="{Binding Data.TeamFilter.ShowTeamColumn, Source={StaticResource VmProxy},
                         Converter={StaticResource BoolToVisibleConverter}}">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <Border Background="{StaticResource AccentSoft}" CornerRadius="9" Padding="8,2"
                      HorizontalAlignment="Left" VerticalAlignment="Center"
                      Visibility="{Binding ShowTeam, Converter={StaticResource BoolToVisibleConverter}}">
                <TextBlock Text="{Binding TeamName}" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource Accent}"/>
              </Border>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>

        <!-- TYPE: inline-editable ComboBox (TypeOptions) bound to EditType. Setting it commits via the row. -->
        <DataGridTemplateColumn Header="TYPE" Width="120" MinWidth="110">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <ComboBox Style="{StaticResource CompactComboBox}" VerticalAlignment="Center"
                        ItemsSource="{Binding TypeOptions}"
                        SelectedItem="{Binding EditType, Mode=TwoWay}"
                        SelectionChanged="OnRowInlineComboChanged"/>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>

        <!-- PCT: ComboBox(AssigneeOptions); SelectedValue=user id (null = "—" sentinel) bound to EditPctUserId. -->
        <DataGridTemplateColumn Header="PCT" Width="*" MinWidth="110">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <ComboBox Style="{StaticResource CompactComboBox}" VerticalAlignment="Center"
                        ItemsSource="{Binding AssigneeOptions}"
                        SelectedValuePath="Id" DisplayMemberPath="Name"
                        SelectedValue="{Binding EditPctUserId, Mode=TwoWay}"
                        SelectionChanged="OnRowInlineComboChanged"/>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>

        <!-- PCA: ComboBox(PcaOptions); SelectedValue=contact id (null = "—" sentinel) bound to EditPcaId. -->
        <DataGridTemplateColumn Header="PCA" Width="*" MinWidth="110">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <ComboBox Style="{StaticResource CompactComboBox}" VerticalAlignment="Center"
                        ItemsSource="{Binding PcaOptions}"
                        SelectedValuePath="Id" DisplayMemberPath="Name"
                        SelectedValue="{Binding EditPcaId, Mode=TwoWay}"
                        SelectionChanged="OnRowInlineComboChanged"/>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>

        <!-- INTERNAL / EXTERNAL deadline: DatePicker. SelectedDate is OneWay (display only — NEVER TwoWay to a
             read-only VM prop). A genuine user pick is caught by SelectedDateChanged in code-behind, which shows
             the reason popup then calls CommitDeadlineAsync; Tag carries the row + which deadline this picker is. -->
        <DataGridTemplateColumn Header="INTERNAL" Width="Auto" MinWidth="128">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <DatePicker Style="{StaticResource CompactDatePicker}" VerticalAlignment="Center" Tag="{Binding}"
                          SelectedDate="{Binding DeadlineInternal, Mode=OneWay, Converter={StaticResource DateOnly}}"
                          SelectedDateChanged="OnInternalDeadlineChanged"/>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTemplateColumn Header="EXTERNAL" Width="Auto" MinWidth="128">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <DatePicker Style="{StaticResource CompactDatePicker}" VerticalAlignment="Center" Tag="{Binding}"
                          SelectedDate="{Binding DeadlineExternal, Mode=OneWay, Converter={StaticResource DateOnly}}"
                          SelectedDateChanged="OnExternalDeadlineChanged"/>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>

        <!-- Progress: DISPLAY mode = % bar (click to edit); EDIT mode = a 0-100 number input. Click the
             bar → IsEditingProgress=true swaps in the TextBox (auto-focused); Enter or click-away commits
             (via EditProgressText, LostFocus) and swaps back to the bar. Bar stays OneWay (NEVER TwoWay to
             ProgressBar.Value). Reload after commit re-seeds the row so the bar reflects the new %. -->
        <DataGridTemplateColumn Header="PROGRESS" Width="150" MinWidth="140">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <Grid VerticalAlignment="Center">
                <!-- Display: click anywhere on the bar/percent to start editing. -->
                <StackPanel Orientation="Horizontal" Background="Transparent" Cursor="Hand"
                            ToolTip="Click to edit progress (0-100%)"
                            MouseLeftButtonUp="OnProgressDisplayClick"
                            Visibility="{Binding IsEditingProgress, ConverterParameter=Invert,
                                         Converter={StaticResource BoolToVisibleConverter}}">
                  <ProgressBar Width="60" Height="8" Minimum="0" Maximum="100"
                               Value="{Binding ProgressPercent, Mode=OneWay, FallbackValue=0, TargetNullValue=0}"
                               Foreground="{StaticResource Accent}"
                               Visibility="{Binding HasProgress, Converter={StaticResource BoolToVisibleConverter}}"/>
                  <TextBlock Text="{Binding ProgressText}" Margin="6,0,0,0" VerticalAlignment="Center"
                             FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                </StackPanel>
                <!-- Edit: number input, auto-focused; Enter / lost-focus commits, Escape cancels. -->
                <TextBox Width="46" HorizontalAlignment="Left" FontSize="12" MaxLength="3"
                         VerticalContentAlignment="Center" TextAlignment="Right"
                         ToolTip="Enter 0-100, then press Enter or click away (blank to clear)"
                         Visibility="{Binding IsEditingProgress, Converter={StaticResource BoolToVisibleConverter}}"
                         Text="{Binding EditProgressText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         IsVisibleChanged="OnProgressEditVisibleChanged"
                         PreviewKeyDown="OnProgressEditKeyDown"
                         LostFocus="OnProgressEditLostFocus"/>
              </Grid>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>

        <DataGridTextColumn Header="LOGGED" Binding="{Binding LoggedHoursText}" Width="Auto" MinWidth="84"
                            ElementStyle="{StaticResource GridCellText}"/>
        <DataGridTextColumn Header="ESTIMATE" Binding="{Binding EstimateText}" Width="Auto" MinWidth="98"
                            ElementStyle="{StaticResource GridCellText}"/>

        <!-- TAGS: the live chips (system late/warning + current custom tags) stay for display, plus the
             inline TagPicker to edit the custom-tag set (toggling a tag commits the whole set via the row).
             Star-sized so it soaks up slack on a wide window; MinWidth keeps labels readable. -->
        <DataGridTemplateColumn Header="TAGS" Width="1.5*" MinWidth="200">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ItemsControl ItemsSource="{Binding Chips}" ItemTemplate="{StaticResource ChipTemplate}"
                              VerticalAlignment="Center">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
                <ctrl:TagPicker ItemsSource="{Binding EditTagPicks}" Margin="4,0,0,0" VerticalAlignment="Center"/>
              </StackPanel>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
      </DataGrid.Columns>

      <!-- Row detail: the backlog's tasks, now inline-editable (PCT / TYPE / STATUS / tags) per TaskRowVm
           (shown when the row is expanded). Each editable prop commits to TaskRepository via the owning VM. -->
      <DataGrid.RowDetailsTemplate>
        <DataTemplate>
          <Border Background="{StaticResource HeaderBg}" Padding="10,6" Margin="34,0,0,0">
           <StackPanel>
            <!-- Empty-state: a backlog with no active tasks expands to this hint instead of a blank strip. -->
            <TextBlock Text="Chưa có task nào trong backlog này."
                       Foreground="{StaticResource TextSecondary}" FontStyle="Italic" FontSize="12"
                       Visibility="{Binding HasNoTasks, Converter={StaticResource BoolToVisibleConverter}}"/>
            <ItemsControl ItemsSource="{Binding TaskRows}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="0,3">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" MinWidth="120"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Task name stays visible (read-only). -->
                    <TextBlock Grid.Column="0" Text="{Binding TaskName}" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                    <!-- TYPE -> EditType. -->
                    <ComboBox Grid.Column="1" Width="110" Margin="0,0,6,0"
                              Style="{StaticResource CompactComboBox}" VerticalAlignment="Center"
                              ItemsSource="{Binding TypeOptions}"
                              SelectedItem="{Binding EditType, Mode=TwoWay}"
                              SelectionChanged="OnTaskExtendedComboChanged"/>
                    <!-- PCT -> EditPctUserId (SelectedValue = user id, null = "—"). -->
                    <ComboBox Grid.Column="2" Width="130" Margin="0,0,6,0"
                              Style="{StaticResource CompactComboBox}" VerticalAlignment="Center"
                              ItemsSource="{Binding AssigneeOptions}"
                              SelectedValuePath="Id" DisplayMemberPath="Name"
                              SelectedValue="{Binding EditPctUserId, Mode=TwoWay}"
                              SelectionChanged="OnTaskExtendedComboChanged"/>
                    <!-- STATUS -> EditStatus. -->
                    <ComboBox Grid.Column="3" Width="110" Margin="0,0,6,0"
                              Style="{StaticResource CompactComboBox}" VerticalAlignment="Center"
                              ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding EditStatus, Mode=TwoWay}"
                              SelectionChanged="OnTaskStatusComboChanged"/>
                    <!-- TAGS -> the task's checkable tag set (toggling commits via SetTaskTagsAsync). -->
                    <ctrl:TagPicker Grid.Column="4" VerticalAlignment="Center"
                                    ItemsSource="{Binding EditTagPicks}"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
           </StackPanel>
          </Border>
        </DataTemplate>
      </DataGrid.RowDetailsTemplate>

      <!-- Bind each row's detail visibility directly to its IsExpanded flag (a direct binding updates
           reliably whenever the command flips IsExpanded; the prior DataTrigger never fired because the
           old toggle wasn't writing IsExpanded). -->
      <DataGrid.RowStyle>
        <Style TargetType="DataGridRow">
          <Setter Property="DetailsVisibility"
                  Value="{Binding IsExpanded, Converter={StaticResource BoolToVisibleConverter}}"/>
        </Style>
      </DataGrid.RowStyle>
    </DataGrid>
  </DockPanel>
</UserControl>
