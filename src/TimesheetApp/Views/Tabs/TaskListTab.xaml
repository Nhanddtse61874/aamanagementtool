<UserControl x:Class="TimesheetApp.Views.Tabs.TaskListTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TimesheetApp.ViewModels"
             xmlns:ctrl="clr-namespace:TimesheetApp.Views.Controls"
             xmlns:beh="clr-namespace:TimesheetApp.Views.Behaviors"
             xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase">
  <UserControl.Resources>
    <!-- Local style helpers: show-when-true / show-when-false / collapse-when-true, keyed off a bool
         binding, so this tab needs no new IValueConverter (W3 owns the converter set). -->
    <Style x:Key="ShowWhenTrue" TargetType="FrameworkElement">
      <Setter Property="Visibility" Value="Collapsed"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsGantt}" Value="True">
          <Setter Property="Visibility" Value="Visible"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="ShowWhenGrid" TargetType="FrameworkElement">
      <Setter Property="Visibility" Value="Visible"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsGantt}" Value="True">
          <Setter Property="Visibility" Value="Collapsed"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <!-- Chip template shared by the grid. System chips use fixed amber/red theme brushes; custom tags
         use HexToBrush over the tag's hex color + its icon glyph. -->
    <DataTemplate x:Key="ChipTemplate" DataType="{x:Type vm:TaskListChipVm}">
      <Border CornerRadius="10" Padding="9,2" Margin="0,0,5,0" VerticalAlignment="Center">
        <Border.Style>
          <Style TargetType="Border">
            <!-- default = custom tag: HexToBrush background -->
            <Setter Property="Background" Value="{Binding Color, Converter={StaticResource HexToBrush}}"/>
            <Style.Triggers>
              <!-- system Warning chip = amber -->
              <DataTrigger Binding="{Binding IsSystem}" Value="True">
                <Setter Property="Background" Value="{StaticResource AmberBg}"/>
                <Setter Property="BorderBrush" Value="{StaticResource AmberBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
              </DataTrigger>
              <!-- system Late chip = red -->
              <DataTrigger Binding="{Binding IsLate}" Value="True">
                <Setter Property="Background" Value="{StaticResource Danger}"/>
                <Setter Property="BorderThickness" Value="0"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="{Binding Icon}" Margin="0,0,5,0" VerticalAlignment="Center"
                     FontFamily="Segoe UI Emoji"
                     Visibility="{Binding Icon, Converter={StaticResource NullToCollapsedConverter}}"/>
          <TextBlock Text="{Binding Text}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <!-- custom tag text = white on the tag color -->
                <Setter Property="Foreground" Value="White"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsSystem}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource AmberFg}"/>
                  </DataTrigger>
                  <DataTrigger Binding="{Binding IsLate}" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </StackPanel>
      </Border>
    </DataTemplate>

    <!-- Proxy so a card element can bind to the owning VM (GroupByProject / ToggleExpandCommand) even though
         the card's own DataContext is the row VM. Data = the UserControl DataContext (the TaskListViewModel). -->
    <ctrl:BindingProxy x:Key="VmProxy" Data="{Binding}"/>

    <!-- P15: group the rows into collapsible section bands. Grouped by GroupKey (adaptive: Team when
         multi-team else Project); sorted by GroupOrder (band order) then BacklogCode (within-band order),
         so bands render in a stable order WITHOUT reordering the VM's Rows (the Gantt reads Rows directly). -->
    <CollectionViewSource x:Key="GroupedRows" Source="{Binding Rows}">
      <CollectionViewSource.GroupDescriptions>
        <PropertyGroupDescription PropertyName="GroupKey"/>
      </CollectionViewSource.GroupDescriptions>
      <CollectionViewSource.SortDescriptions>
        <scm:SortDescription PropertyName="GroupOrder" Direction="Ascending"/>
        <scm:SortDescription PropertyName="BacklogCode" Direction="Ascending"/>
      </CollectionViewSource.SortDescriptions>
    </CollectionViewSource>
  </UserControl.Resources>

  <DockPanel Margin="12">

    <!-- Controls: month selector + Grid/Gantt toggle + collapse-chart toggle + Export this month. -->
    <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,8">
      <StackPanel Orientation="Horizontal" Margin="0,0,16,6">
        <TextBlock Text="Month:" VerticalAlignment="Center" Margin="0,0,4,0"/>
        <!-- ISSUE 3: month 0 = "All months" (lists every backlog like the Backlog tab); 1-12 filter. -->
        <ComboBox Width="86" ItemsSource="{Binding Months}" SelectedItem="{Binding SelectedMonth}">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock>
                <TextBlock.Style>
                  <Style TargetType="TextBlock">
                    <Setter Property="Text" Value="{Binding}"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding}" Value="0">
                        <Setter Property="Text" Value="All months"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
        <ComboBox Width="86" Margin="6,0,0,0" ItemsSource="{Binding Years}" SelectedItem="{Binding SelectedYear}"/>
        <!-- P10 (TM-07): multi-team checkbox filter (hidden for single-team users). -->
        <ctrl:TeamFilter DataContext="{Binding TeamFilter}" Margin="14,0,0,0" VerticalAlignment="Center"/>
      </StackPanel>

      <!-- Grid↔Gantt segmented control (two themed ToggleButtons; clicks set IsGantt in code-behind,
           IsChecked reflects it — ToolbarGhostToggle gives a clear accent on the active one). -->
      <StackPanel Orientation="Horizontal" Margin="0,0,16,6">
        <ToggleButton x:Name="GridToggle" Content="Grid" IsChecked="True" Click="OnSelectGrid"
                      Padding="14,4" Style="{StaticResource ToolbarGhostToggle}"/>
        <ToggleButton x:Name="GanttToggle" Content="Gantt" Click="OnSelectGantt"
                      Padding="14,4" Style="{StaticResource ToolbarGhostToggle}"/>
      </StackPanel>

      <ToggleButton IsChecked="{Binding IsChartCollapsed}" Padding="14,4" Margin="0,0,16,6"
                    ToolTip="Show / hide the chart area">
        <ToggleButton.Style>
          <Style TargetType="ToggleButton" BasedOn="{StaticResource ToolbarGhostToggle}">
            <Setter Property="Content" Value="Hide chart"/>
            <Style.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter Property="Content" Value="Show chart"/>
              </Trigger>
            </Style.Triggers>
          </Style>
        </ToggleButton.Style>
      </ToggleButton>

      <Button Content="&#11015; Export this month" Command="{Binding ExportThisMonthCommand}"
              Style="{StaticResource ToolbarButton}" Margin="0,0,12,6"
              ToolTip="Write this month's Task List overview to a markdown file"/>
      <TextBlock Text="{Binding ExportStatus}" Foreground="{StaticResource TextSecondary}"
                 VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
    </WrapPanel>

    <!-- Collapsible chart area (Gantt placeholder for Wave 6). Collapses via IsChartCollapsed. -->
    <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBg}"
            BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8"
            MinHeight="120" MaxHeight="320" Margin="0,0,0,10" Padding="12">
      <Border.Style>
        <Style TargetType="Border">
          <Setter Property="Visibility" Value="Visible"/>
          <Style.Triggers>
            <DataTrigger Binding="{Binding IsChartCollapsed}" Value="True">
              <Setter Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <!-- Gantt canvas (shown when IsGantt). Horizontally scrollable; bars are drawn in code-behind
           reading ActualWidth post-layout (R5). When in Grid mode, a hint sits in its place. -->
      <Grid>
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      Style="{StaticResource ShowWhenTrue}">
          <Canvas x:Name="GanttCanvas" Background="Transparent"
                  SizeChanged="OnGanttCanvasSizeChanged"/>
        </ScrollViewer>
        <TextBlock Text="Switch to Gantt to see the timeline." Foreground="{StaticResource TextSecondary}"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource ShowWhenGrid}"/>
      </Grid>
    </Border>

    <!-- GRID view (P16): one CARD per non-DEFAULT backlog in the selected month, under Log Work-style section
         bands (adaptive Team/Project grouping from P15). Tags sit in a full-width strip on TOP of each card
         (always visible → no horizontal scroll); the rest of the fields live in a collapsible detail area.
         Wrapped in the rounded TableContainer; hidden as a whole in Gantt mode. -->
    <Border>
      <Border.Style>
        <Style TargetType="Border" BasedOn="{StaticResource TableContainer}">
          <Style.Triggers>
            <DataTrigger Binding="{Binding IsGantt}" Value="True">
              <Setter Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>

      <!-- Vertical scroll only — tags are on top and fields wrap, so there is never a horizontal scroll. -->
      <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding Source={StaticResource GroupedRows}}" Margin="6"
                      beh:RoundedClip.Radius="8">

          <!-- Section band per group (Project/Team), collapsible; moved verbatim from P15's DataGrid.GroupStyle. -->
          <ItemsControl.GroupStyle>
            <GroupStyle>
              <GroupStyle.ContainerStyle>
                <Style TargetType="{x:Type GroupItem}">
                  <Setter Property="Template">
                    <Setter.Value>
                      <ControlTemplate TargetType="{x:Type GroupItem}">
                        <Expander IsExpanded="True" Background="{StaticResource HeaderBg}"
                                  BorderThickness="0" Padding="0" Margin="0,0,0,4">
                          <Expander.Header>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                              <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                                         Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                              <TextBlock Text="{Binding ItemCount, StringFormat=' ({0})'}" VerticalAlignment="Center"
                                         Margin="2,0,0,0" Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>
                          </Expander.Header>
                          <ItemsPresenter/>
                        </Expander>
                      </ControlTemplate>
                    </Setter.Value>
                  </Setter>
                </Style>
              </GroupStyle.ContainerStyle>
            </GroupStyle>
          </ItemsControl.GroupStyle>

          <!-- One backlog = one card. -->
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:TaskListRowVm}">
              <Border Margin="0,0,0,8" Padding="10" CornerRadius="8"
                      BorderBrush="{StaticResource Border}" BorderThickness="1" Background="White">
                <Border.Style>
                  <Style TargetType="Border">
                    <Style.Triggers>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#F8FAFC"/>
                      </Trigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <StackPanel>

                  <!-- Tag strip (full-width, always on top): live chips + the ✎ Tags edit button (modal dialog). -->
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6">
                    <ItemsControl ItemsSource="{Binding Chips}" ItemTemplate="{StaticResource ChipTemplate}"
                                  VerticalAlignment="Center">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                    </ItemsControl>
                    <Button Content="✎ Tags" Style="{StaticResource MiniGhostButton}" Padding="8,2" Margin="6,0,0,0"
                            VerticalAlignment="Center" Click="OnEditBacklogTagsClick"
                            ToolTip="Sửa tag của backlog"/>
                  </StackPanel>

                  <!-- Compact header: caret · CODE · (Project only in Team-grouping) · PCT · Internal · Progress. -->
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Expand/collapse the detail (fields + tasks). Reliable command via VmProxy (not IsChecked). -->
                    <Button Grid.Column="0" Command="{Binding Data.ToggleExpandCommand, Source={StaticResource VmProxy}}"
                            CommandParameter="{Binding}" Padding="2" Width="24" VerticalAlignment="Center"
                            ToolTip="Hiện / ẩn chi tiết + task">
                      <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MiniGhostButton}">
                          <Setter Property="Content" Value="&#9656;"/>
                          <Setter Property="FontSize" Value="11"/>
                          <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                              <Setter Property="Content" Value="&#9662;"/>
                              <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Button.Style>
                    </Button>

                    <TextBlock Grid.Column="1" Text="{Binding BacklogCode}" FontWeight="SemiBold" FontSize="13"
                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                    <!-- Project shown only when grouped by Team (band shows Project otherwise). -->
                    <TextBlock Grid.Column="2" Text="{Binding Project}" Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center" Margin="8,0,0,0"
                               Visibility="{Binding Data.GroupByProject, Source={StaticResource VmProxy},
                                            Converter={StaticResource BoolToVisibleConverter}, ConverterParameter=Invert}"/>

                    <!-- PCT (assignee), TwoWay — in an ItemsControl the write reaches the row VM directly
                         (the DataGrid CellTemplate write-back bug does not apply), firing OnEditPctUserIdChanged. -->
                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                      <TextBlock Text="PCT" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                      <ComboBox Style="{StaticResource CompactComboBox}" Width="120" VerticalAlignment="Center"
                                ItemsSource="{Binding AssigneeOptions}" SelectedValuePath="Id" DisplayMemberPath="Name"
                                SelectedValue="{Binding EditPctUserId, Mode=TwoWay}"/>
                    </StackPanel>

                    <!-- Internal deadline (OneWay display + code-behind reason-note popup commit). -->
                    <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                      <TextBlock Text="Internal" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                      <DatePicker Style="{StaticResource CompactDatePicker}" VerticalAlignment="Center" Tag="{Binding}"
                                  SelectedDate="{Binding DeadlineInternal, Mode=OneWay, Converter={StaticResource DateOnly}}"
                                  SelectedDateChanged="OnInternalDeadlineChanged"/>
                    </StackPanel>

                    <!-- External deadline in the compact header too (OneWay + code-behind reason-note popup). -->
                    <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                      <TextBlock Text="External" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                      <DatePicker Style="{StaticResource CompactDatePicker}" VerticalAlignment="Center" Tag="{Binding}"
                                  SelectedDate="{Binding DeadlineExternal, Mode=OneWay, Converter={StaticResource DateOnly}}"
                                  SelectedDateChanged="OnExternalDeadlineChanged"/>
                    </StackPanel>

                    <!-- Progress: display bar (click to edit) / 0-100 input. Bar stays OneWay (never TwoWay on Value). -->
                    <Grid Grid.Column="7" VerticalAlignment="Center">
                      <StackPanel Orientation="Horizontal" Background="Transparent" Cursor="Hand"
                                  ToolTip="Click to edit progress (0-100%)"
                                  MouseLeftButtonUp="OnProgressDisplayClick"
                                  Visibility="{Binding IsEditingProgress, ConverterParameter=Invert,
                                               Converter={StaticResource BoolToVisibleConverter}}">
                        <!-- P16: always show the bar; no progress defaults to 0 (TargetNullValue=0). -->
                        <ProgressBar Style="{StaticResource FlatProgressBar}" Width="64" VerticalAlignment="Center"
                                     Minimum="0" Maximum="100"
                                     Value="{Binding ProgressPercent, Mode=OneWay, FallbackValue=0, TargetNullValue=0}"/>
                        <TextBlock Text="{Binding ProgressText}" Margin="6,0,0,0" VerticalAlignment="Center"
                                   FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                      </StackPanel>
                      <TextBox Width="54" Height="26" HorizontalAlignment="Left" VerticalAlignment="Center"
                               Padding="6,2" FontSize="12" MaxLength="3"
                               VerticalContentAlignment="Center" TextAlignment="Center"
                               ToolTip="Enter 0-100, then press Enter or click away (blank to clear)"
                               Visibility="{Binding IsEditingProgress, Converter={StaticResource BoolToVisibleConverter}}"
                               Text="{Binding EditProgressText, Mode=OneWay}"
                               IsVisibleChanged="OnProgressEditVisibleChanged"
                               PreviewKeyDown="OnProgressEditKeyDown"
                               LostFocus="OnProgressEditLostFocus"/>
                    </Grid>
                  </Grid>

                  <!-- Expanded detail: remaining fields (wrap) + editable task sub-rows. -->
                  <StackPanel Margin="30,8,0,0"
                              Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibleConverter}}">
                    <WrapPanel>
                      <!-- Type (TwoWay). -->
                      <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,6">
                        <TextBlock Text="Type" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox Style="{StaticResource CompactComboBox}" Width="120" VerticalAlignment="Center"
                                  ItemsSource="{Binding TypeOptions}"
                                  SelectedItem="{Binding EditType, Mode=TwoWay}"/>
                      </StackPanel>
                      <!-- PCA (TwoWay). -->
                      <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,6">
                        <TextBlock Text="PCA" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox Style="{StaticResource CompactComboBox}" Width="130" VerticalAlignment="Center"
                                  ItemsSource="{Binding PcaOptions}" SelectedValuePath="Id" DisplayMemberPath="Name"
                                  SelectedValue="{Binding EditPcaId, Mode=TwoWay}"/>
                      </StackPanel>
                      <!-- Start (OneWay + commit). -->
                      <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,6">
                        <TextBlock Text="Start" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <DatePicker Style="{StaticResource CompactDatePicker}" VerticalAlignment="Center" Tag="{Binding}"
                                    SelectedDate="{Binding StartDate, Mode=OneWay, Converter={StaticResource DateOnly}}"
                                    SelectedDateChanged="OnStartDateChanged"/>
                      </StackPanel>
                      <!-- End (OneWay + commit). -->
                      <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,6">
                        <TextBlock Text="End" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <DatePicker Style="{StaticResource CompactDatePicker}" VerticalAlignment="Center" Tag="{Binding}"
                                    SelectedDate="{Binding EndDate, Mode=OneWay, Converter={StaticResource DateOnly}}"
                                    SelectedDateChanged="OnEndDateChanged"/>
                      </StackPanel>
                      <!-- Logged / Estimate (display). -->
                      <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,6">
                        <TextBlock Text="Logged" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding LoggedHoursText}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Estimation" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding EstimateText}" VerticalAlignment="Center"/>
                      </StackPanel>
                    </WrapPanel>

                    <!-- Task sub-rows (inline-editable), carried over from the P15 RowDetailsTemplate. -->
                    <TextBlock Text="Chưa có task nào trong backlog này."
                               Foreground="{StaticResource TextSecondary}" FontStyle="Italic" FontSize="12" Margin="0,4,0,0"
                               Visibility="{Binding HasNoTasks, Converter={StaticResource BoolToVisibleConverter}}"/>
                    <ItemsControl ItemsSource="{Binding TaskRows}" Margin="0,4,0,0">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*" MinWidth="120"/>
                              <ColumnDefinition Width="Auto"/>
                              <ColumnDefinition Width="Auto"/>
                              <ColumnDefinition Width="Auto"/>
                              <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Task name stays visible (read-only). -->
                            <TextBlock Grid.Column="0" Text="{Binding TaskName}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                            <!-- TYPE -> EditType. -->
                            <ComboBox Grid.Column="1" Width="110" Margin="0,0,6,0"
                                      Style="{StaticResource CompactComboBox}" VerticalAlignment="Center"
                                      ItemsSource="{Binding TypeOptions}"
                                      SelectedItem="{Binding EditType, Mode=TwoWay}"/>
                            <!-- PCT -> EditPctUserId (SelectedValue = user id, null = "—"). -->
                            <ComboBox Grid.Column="2" Width="130" Margin="0,0,6,0"
                                      Style="{StaticResource CompactComboBox}" VerticalAlignment="Center"
                                      ItemsSource="{Binding AssigneeOptions}"
                                      SelectedValuePath="Id" DisplayMemberPath="Name"
                                      SelectedValue="{Binding EditPctUserId, Mode=TwoWay}"/>
                            <!-- STATUS -> EditStatus. -->
                            <ComboBox Grid.Column="3" Width="110" Margin="0,0,6,0"
                                      Style="{StaticResource CompactComboBox}" VerticalAlignment="Center"
                                      ItemsSource="{Binding StatusOptions}"
                                      SelectedItem="{Binding EditStatus, Mode=TwoWay}"/>
                            <!-- TAGS -> the task's checkable tag set (modal dialog; commits via SetTaskTagsAsync). -->
                            <Button Grid.Column="4" Content="✎ Tags" Style="{StaticResource MiniGhostButton}"
                                    Padding="8,2" VerticalAlignment="Center" Click="OnEditTaskTagsClick"
                                    ToolTip="Sửa tag của task"/>
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>

                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>
  </DockPanel>
</UserControl>
