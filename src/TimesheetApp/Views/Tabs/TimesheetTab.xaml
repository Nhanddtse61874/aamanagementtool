<UserControl x:Class="TimesheetApp.Views.Tabs.TimesheetTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:TimesheetApp.Views.Converters">
  <UserControl.Resources>
    <conv:OverEightTagConverter x:Key="OverEightTag"/>

    <!-- Footer total TextBlock: turns red when Tag = True (i.e. total > 8h) -->
    <Style x:Key="TotalTextBlock" TargetType="TextBlock">
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="True">
          <Setter Property="Foreground" Value="{StaticResource Danger}"/>
          <Setter Property="FontWeight" Value="Bold"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <!-- Day cells are centred so the value sits in the middle of each star column — this keeps the
         columns visually aligned with the (also-centred) header strip + footer at ANY window size,
         independent of cell padding or the scrollbar gutter. -->
    <Style x:Key="DayCell" TargetType="TextBlock">
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ISSUE 5 (HOL-02): a day-column cell whose date is a marked holiday gets a muted grey fill (read as
         a non-working day, like a weekend); Tag carries the per-day holiday flag. -->
    <Style x:Key="HolidayCellBorder" TargetType="Border">
      <Style.Triggers>
        <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="True">
          <Setter Property="Background" Value="{StaticResource HolidayBg}"/>
          <Setter Property="ToolTip" Value="Holiday — not a working day"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <!-- Borderless in-grid editable day cell (LostFocus -> per-cell auto-save; red on invalid). -->
    <Style x:Key="GridDayBox" TargetType="TextBox">
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Padding" Value="0,5"/>
      <!-- Shows a "Holiday" watermark when the owning cell Border is a holiday (Tag=True). Holiday cells
           are read-only + always empty, so the watermark reads as "no work expected" over the empty box.
           Keeps PART_ContentHost so editing/validation on non-holiday cells is unchanged. -->
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Grid Background="{TemplateBinding Background}">
              <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
              <TextBlock x:Name="holidayHint" Text="Holiday" Visibility="Collapsed" IsHitTestVisible="False"
                         FontSize="11" Foreground="{StaticResource TextSecondary}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
            <ControlTemplate.Triggers>
              <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                <Setter TargetName="holidayHint" Property="Visibility" Value="Visible"/>
              </DataTrigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Backlog "section" row: a full-width clickable band that collapses/expands its tasks. -->
    <Style x:Key="SectionToggle" TargetType="ToggleButton">
      <Setter Property="Background" Value="{StaticResource TableHeaderBg}"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border x:Name="bd" Background="{TemplateBinding Background}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
              <ContentPresenter VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="{StaticResource HeaderBg}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Expand/collapse caret that flips with the group's IsExpanded. -->
    <Style x:Key="SectionCaret" TargetType="TextBlock">
      <Setter Property="Text" Value="&#9662;"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Margin" Value="0,0,8,0"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsExpanded}" Value="False">
          <Setter Property="Text" Value="&#9656;"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>
  </UserControl.Resources>

  <DockPanel LastChildFill="True">

    <!-- Week navigation toolbar (TS-01) — compact; week total anchored to the right edge. -->
    <DockPanel DockPanel.Dock="Top" Margin="8,8,8,6">

      <!-- Week total chip (right) -->
      <Border DockPanel.Dock="Right" Background="{StaticResource HeaderBg}" CornerRadius="7"
              Padding="12,3" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="Week total" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"
                     Foreground="{StaticResource TableHeaderText}" Margin="0,0,8,0"/>
          <TextBlock Text="{Binding WeekTotal, StringFormat='{}{0:N1}h'}" FontSize="15" FontWeight="Bold"
                     Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
        </StackPanel>
      </Border>

      <!-- Left group: segmented week nav + Save + Smart fill -->
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <!-- Segmented prev / week / next -->
        <Border BorderBrush="{StaticResource BorderStrong}" BorderThickness="1" CornerRadius="6"
                Background="{StaticResource Surface}">
          <StackPanel Orientation="Horizontal">
            <Button Content="&#9664; Prev" Command="{Binding PreviousWeekCommand}"
                    Style="{StaticResource GhostButton}" BorderThickness="0" Padding="12,4"
                    Margin="0" ToolTip="Previous week"/>
            <TextBlock Text="{Binding CurrentWeek, StringFormat='Week of {0:dd/MM/yyyy}'}"
                       VerticalAlignment="Center" Margin="8,0" FontWeight="SemiBold" FontSize="13"/>
            <Button Content="Next &#9654;" Command="{Binding NextWeekCommand}"
                    Style="{StaticResource GhostButton}" BorderThickness="0" Padding="12,4"
                    Margin="0" ToolTip="Next week"/>
          </StackPanel>
        </Border>

        <!-- Jump to any week: picking a date snaps the grid to that date's Monday -->
        <DatePicker SelectedDate="{Binding JumpDate, Mode=TwoWay}" Width="128" Margin="8,0,0,0"
                    VerticalAlignment="Center" ToolTip="Jump to the week containing a date"/>

        <!-- Auto-save status (replaces the old Save button): cells persist on commit. Only takes space
             when it has something to show, so the toolbar layout is identical across User selections. -->
        <TextBlock Text="{Binding SaveStatus}" VerticalAlignment="Center" Margin="12,0,8,0"
                   FontSize="12" FontWeight="SemiBold">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Foreground" Value="{StaticResource BadgeGreenFg}"/>
              <Setter Property="Visibility" Value="Visible"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding SaveStatus}" Value="">
                  <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding SaveStatusIsError}" Value="True">
                  <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
        <Button Content="&#9889; Smart fill" Click="OnSmartFill"
                Style="{StaticResource ToolbarGhostButton}" IsEnabled="{Binding CanEdit}"
                ToolTip="Auto-fill hours for one task over a date range (split evenly / full 8h)"/>
        <Button Command="{Binding ToggleCollapseAllCommand}"
                Style="{StaticResource ToolbarGhostButton}"
                ToolTip="Collapse / expand all backlog groups">
          <TextBlock><Run Text="&#9776; "/><Run Text="{Binding CollapseToggleText, Mode=OneWay}"/></TextBlock>
        </Button>
      </StackPanel>
    </DockPanel>

    <!-- v2: Entry user filter (Cả team / other user) + month filter -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,2,8,4">
      <TextBlock Text="User:" VerticalAlignment="Center" Margin="0,0,6,0"/>
      <ComboBox Width="200" ItemsSource="{Binding Targets}" SelectedItem="{Binding SelectedTarget}"
                DisplayMemberPath="Display"/>
      <TextBlock Text="Month:" VerticalAlignment="Center" Margin="16,0,6,0"/>
      <ComboBox Width="56" ItemsSource="{Binding Months}" SelectedItem="{Binding FilterMonthNumber}"
                Margin="0,0,6,0" ToolTip="Show only tickets in the selected month"/>
      <ComboBox Width="80" ItemsSource="{Binding Years}" SelectedItem="{Binding FilterYear}"/>
      <Border Background="{StaticResource AmberBg}" CornerRadius="7" Padding="10,3" Margin="16,0,0,0"
              VerticalAlignment="Center"
              Visibility="{Binding IsReadOnly, Converter={StaticResource BoolToVisibleConverter}}">
        <TextBlock Text="Read-only (whole team)" FontSize="12" FontWeight="SemiBold"
                   Foreground="{StaticResource AmberFg}"/>
      </Border>
    </StackPanel>

    <!-- Per-column footer totals strip across ALL groups (TS-05, TS-06).
         Right margin = scrollbar gutter (~17) + 8 so the columns line up with the scrollable data. -->
    <Border DockPanel.Dock="Bottom" Margin="8,2,25,8" Background="{StaticResource TableHeaderBg}"
            BorderBrush="{StaticResource BorderStrong}" BorderThickness="1">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="2*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="DAY TOTALS" FontWeight="Bold" VerticalAlignment="Center" Margin="10,6"
                   Foreground="{StaticResource TableHeaderText}"/>
        <Border Grid.Column="1" BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0" Padding="0,6">
          <TextBlock Text="{Binding MonTotal, StringFormat=N1}" Tag="{Binding MonTotal, Converter={StaticResource OverEightTag}}" Style="{StaticResource TotalTextBlock}"/>
        </Border>
        <Border Grid.Column="2" BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0" Padding="0,6">
          <TextBlock Text="{Binding TueTotal, StringFormat=N1}" Tag="{Binding TueTotal, Converter={StaticResource OverEightTag}}" Style="{StaticResource TotalTextBlock}"/>
        </Border>
        <Border Grid.Column="3" BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0" Padding="0,6">
          <TextBlock Text="{Binding WedTotal, StringFormat=N1}" Tag="{Binding WedTotal, Converter={StaticResource OverEightTag}}" Style="{StaticResource TotalTextBlock}"/>
        </Border>
        <Border Grid.Column="4" BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0" Padding="0,6">
          <TextBlock Text="{Binding ThuTotal, StringFormat=N1}" Tag="{Binding ThuTotal, Converter={StaticResource OverEightTag}}" Style="{StaticResource TotalTextBlock}"/>
        </Border>
        <Border Grid.Column="5" BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0" Padding="0,6">
          <TextBlock Text="{Binding FriTotal, StringFormat=N1}" Tag="{Binding FriTotal, Converter={StaticResource OverEightTag}}" Style="{StaticResource TotalTextBlock}"/>
        </Border>
        <Border Grid.Column="6" BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0" Padding="0,6">
          <TextBlock Text="{Binding WeekTotal, StringFormat=N1}" FontWeight="Bold"
                     HorizontalAlignment="Center" Foreground="{StaticResource Accent}"/>
        </Border>
      </Grid>
    </Border>

    <!-- Column-header strip so the per-group DataGrids (headers hidden) stay aligned (Excel-like cells). -->
    <Border DockPanel.Dock="Top" Margin="8,4,25,0" Background="{StaticResource TableHeaderBg}"
            BorderBrush="{StaticResource BorderStrong}" BorderThickness="1,1,1,0">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="2*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="TASK" FontWeight="Bold" Margin="10,7"
                   Foreground="{StaticResource TableHeaderText}"/>
        <Border Grid.Column="1" BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0" Padding="0,7">
          <TextBlock Text="{Binding MonHeader}" FontWeight="Bold" HorizontalAlignment="Center"/></Border>
        <Border Grid.Column="2" BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0" Padding="0,7">
          <TextBlock Text="{Binding TueHeader}" FontWeight="Bold" HorizontalAlignment="Center"/></Border>
        <Border Grid.Column="3" BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0" Padding="0,7">
          <TextBlock Text="{Binding WedHeader}" FontWeight="Bold" HorizontalAlignment="Center"/></Border>
        <Border Grid.Column="4" BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0" Padding="0,7">
          <TextBlock Text="{Binding ThuHeader}" FontWeight="Bold" HorizontalAlignment="Center"/></Border>
        <Border Grid.Column="5" BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0" Padding="0,7">
          <TextBlock Text="{Binding FriHeader}" FontWeight="Bold" HorizontalAlignment="Center"/></Border>
        <Border Grid.Column="6" BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0" Padding="0,7">
          <TextBlock Text="TOTAL" FontWeight="Bold" HorizontalAlignment="Center"
                     Foreground="{StaticResource TableHeaderText}"/></Border>
      </Grid>
    </Border>

    <!-- Drag-to-delete zone for task rows (pinned just above the day-totals footer; editable view only). -->
    <Border x:Name="TaskTrash" DockPanel.Dock="Bottom" AllowDrop="True" Drop="OnTaskTrashDrop"
            DragEnter="OnTaskTrashDragOver" DragOver="OnTaskTrashDragOver" DragLeave="OnTaskTrashDragLeave"
            Background="{StaticResource AmberBg}" BorderBrush="{StaticResource AmberBorder}" BorderThickness="1"
            CornerRadius="8" Padding="10,7" Margin="8,4,25,4"
            Visibility="{Binding CanEdit, Converter={StaticResource BoolToVisibleConverter}}">
      <TextBlock Text="&#128465;  Drop a task here to delete" HorizontalAlignment="Center"
                 Foreground="{StaticResource AmberFg}" FontSize="12" FontWeight="SemiBold"/>
    </Border>

    <!-- Single continuous table body: one "section" band per backlog, its task rows beneath (each with
         editable Mon–Fri cells). Scrollbar is ALWAYS reserved (Visible) so the columns line up with the
         header strip + footer (which reserve a matching 25px right gutter) at any window size. -->
    <ScrollViewer VerticalScrollBarVisibility="Visible" Margin="8,0">
      <ItemsControl ItemsSource="{Binding Groups}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <StackPanel>

              <!-- ===== Backlog section row (click to collapse/expand) ===== -->
              <ToggleButton Style="{StaticResource SectionToggle}" IsChecked="{Binding IsExpanded, Mode=TwoWay}">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>

                  <!-- Left: caret + code · project + status/month/assignee badges + Move.
                       Spans the day columns so badges/Move have room (only the total sits in col 6). -->
                  <StackPanel Grid.Column="0" Grid.ColumnSpan="6" Orientation="Horizontal" Margin="10,6">
                    <TextBlock Style="{StaticResource SectionCaret}"/>
                    <TextBlock Text="{Binding BacklogCode}" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Project, StringFormat=' · {0}'}" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondary}"
                               Visibility="{Binding Project, Converter={StaticResource NullToCollapsedConverter}}"/>
                    <Border Background="{StaticResource AccentSoft}" CornerRadius="9" Padding="8,1" Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            Visibility="{Binding Type, Converter={StaticResource NullToCollapsedConverter}}">
                      <TextBlock Text="{Binding Type}" FontSize="11" FontWeight="SemiBold"
                                 Foreground="{StaticResource Accent}"/>
                    </Border>
                    <TextBlock Text="{Binding PeriodMonth}" FontSize="11" Margin="8,0,0,0"
                               VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                    <Border Background="{StaticResource HeaderBg}" CornerRadius="9" Padding="8,1" Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Visibility="{Binding AssigneeName, Converter={StaticResource NullToCollapsedConverter}}">
                      <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}">
                        <Run Text="&#128100; "/><Run Text="{Binding AssigneeName, Mode=OneWay}"/>
                      </TextBlock>
                    </Border>
                  </StackPanel>

                  <!-- Right: group total aligned under the TOTAL column -->
                  <TextBlock Grid.Column="6" Text="{Binding GroupTotal, StringFormat='{}{0:N1}h'}"
                             FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextSecondary}"
                             HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,6,12,6"/>
                </Grid>
              </ToggleButton>

              <!-- ===== Task rows (shown only when expanded) ===== -->
              <ItemsControl ItemsSource="{Binding Tasks}"
                            Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibleConverter}}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                            Background="{StaticResource Surface}"
                            AllowDrop="True" Drop="OnTaskDrop" DragOver="OnTaskDragOver">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="2*"/>
                          <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <DockPanel Grid.Column="0" Margin="10,5,8,5">
                          <TextBlock DockPanel.Dock="Left" Text="&#9783;" FontSize="15" Cursor="SizeAll"
                                     Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"
                                     ToolTip="Drag to reorder, or drop on the trash to delete"
                                     Visibility="{Binding DataContext.CanEdit, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibleConverter}}"
                                     PreviewMouseLeftButtonDown="OnTaskDragHandleDown" PreviewMouseMove="OnTaskDragHandleMove"/>
                          <TextBlock Text="{Binding TaskName}" VerticalAlignment="Center"
                                     FontSize="13" TextTrimming="CharacterEllipsis"/>
                        </DockPanel>

                        <Border Grid.Column="1" BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0"
                                Style="{StaticResource HolidayCellBorder}"
                                Tag="{Binding DataContext.MonIsHoliday, RelativeSource={RelativeSource AncestorType=UserControl}}">
                          <TextBox Style="{StaticResource GridDayBox}"
                                   IsReadOnly="{Binding DataContext.MonReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   Text="{Binding Mon, UpdateSourceTrigger=LostFocus, TargetNullValue='', ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}"/>
                        </Border>
                        <Border Grid.Column="2" BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0"
                                Style="{StaticResource HolidayCellBorder}"
                                Tag="{Binding DataContext.TueIsHoliday, RelativeSource={RelativeSource AncestorType=UserControl}}">
                          <TextBox Style="{StaticResource GridDayBox}"
                                   IsReadOnly="{Binding DataContext.TueReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   Text="{Binding Tue, UpdateSourceTrigger=LostFocus, TargetNullValue='', ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}"/>
                        </Border>
                        <Border Grid.Column="3" BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0"
                                Style="{StaticResource HolidayCellBorder}"
                                Tag="{Binding DataContext.WedIsHoliday, RelativeSource={RelativeSource AncestorType=UserControl}}">
                          <TextBox Style="{StaticResource GridDayBox}"
                                   IsReadOnly="{Binding DataContext.WedReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   Text="{Binding Wed, UpdateSourceTrigger=LostFocus, TargetNullValue='', ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}"/>
                        </Border>
                        <Border Grid.Column="4" BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0"
                                Style="{StaticResource HolidayCellBorder}"
                                Tag="{Binding DataContext.ThuIsHoliday, RelativeSource={RelativeSource AncestorType=UserControl}}">
                          <TextBox Style="{StaticResource GridDayBox}"
                                   IsReadOnly="{Binding DataContext.ThuReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   Text="{Binding Thu, UpdateSourceTrigger=LostFocus, TargetNullValue='', ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}"/>
                        </Border>
                        <Border Grid.Column="5" BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0"
                                Style="{StaticResource HolidayCellBorder}"
                                Tag="{Binding DataContext.FriIsHoliday, RelativeSource={RelativeSource AncestorType=UserControl}}">
                          <TextBox Style="{StaticResource GridDayBox}"
                                   IsReadOnly="{Binding DataContext.FriReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   Text="{Binding Fri, UpdateSourceTrigger=LostFocus, TargetNullValue='', ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}"/>
                        </Border>
                        <Border Grid.Column="6" BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0">
                          <TextBlock Text="{Binding RowTotal, StringFormat=N1}" FontWeight="SemiBold" FontSize="13"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <!-- Inline add-task row (only when expanded). The "Move to next month" action lives here
                   (right side) instead of cluttering the section header. -->
              <Border BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                      Background="{StaticResource Surface}"
                      Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibleConverter}}">
                <DockPanel Margin="28,4,12,4">
                  <Button DockPanel.Dock="Right" Content="Move to next month &#9654;"
                          Style="{StaticResource MiniGhostButton}" VerticalAlignment="Center"
                          Visibility="{Binding CanMoveMonth, Converter={StaticResource BoolToVisibleConverter}}"
                          IsEnabled="{Binding DataContext.CanEdit, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          Command="{Binding DataContext.MoveMonthCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding BacklogId}"
                          ToolTip="Advance this ticket to the next month (audited)"/>
                  <!-- Add task opens a dedicated input dialog (handled in code-behind per group). -->
                  <Button Content="&#10133; Add task" Click="OnAddTask" HorizontalAlignment="Left"
                          Style="{StaticResource MiniGhostButton}"
                          IsEnabled="{Binding DataContext.CanEdit, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                </DockPanel>
              </Border>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

  </DockPanel>
</UserControl>
