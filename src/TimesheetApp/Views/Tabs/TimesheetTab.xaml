<UserControl x:Class="TimesheetApp.Views.Tabs.TimesheetTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:TimesheetApp.Views.Converters">
  <UserControl.Resources>
    <conv:OverEightTagConverter x:Key="OverEightTag"/>

    <!-- Footer total TextBlock: turns red when Tag = True (i.e. total > 8h) -->
    <Style x:Key="TotalTextBlock" TargetType="TextBlock">
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="True">
          <Setter Property="Foreground" Value="Red"/>
          <Setter Property="FontWeight" Value="Bold"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <!-- Shared day-cell binding template columns are declared per-DataGrid below; the per-group
         DataGrids all use the same Mon..Fri bindings (LostFocus + ValidatesOnNotifyDataErrors). -->
  </UserControl.Resources>

  <DockPanel LastChildFill="True">

    <!-- Week navigation bar (TS-01) -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,8,8,4">
      <Button Content="&#9664; Prev"
              Command="{Binding PreviousWeekCommand}"
              Style="{StaticResource ToolbarGhostButton}"/>
      <TextBlock Text="{Binding CurrentWeek, StringFormat='Week of {0:dd/MM/yyyy}'}"
                 VerticalAlignment="Center" Margin="8,0" FontWeight="Bold"/>
      <Button Content="Next &#9654;"
              Command="{Binding NextWeekCommand}"
              Style="{StaticResource ToolbarGhostButton}"/>
      <Button Content="Save"
              Command="{Binding SaveCommand}"
              Style="{StaticResource ToolbarButton}" Margin="16,0,6,0"/>
      <Button Content="&#9889; Smart fill"
              Click="OnSmartFill"
              Style="{StaticResource ToolbarGhostButton}"
              IsEnabled="{Binding CanEdit}"
              ToolTip="Auto-fill hours for one task over a date range (split evenly / full 8h)"/>

      <!-- Week total chip -->
      <Border Background="{StaticResource HeaderBg}" CornerRadius="7" Padding="12,4" Margin="16,0,0,0">
        <StackPanel>
          <TextBlock Text="WEEK TOTAL" FontSize="10" FontWeight="Bold"
                     Foreground="{StaticResource TableHeaderText}" HorizontalAlignment="Right"/>
          <TextBlock Text="{Binding WeekTotal, StringFormat='{}{0:N1}h'}" FontSize="16" FontWeight="Bold"
                     Foreground="{StaticResource Accent}" HorizontalAlignment="Right"/>
        </StackPanel>
      </Border>
    </StackPanel>

    <!-- v2: Entry user filter (Cả team / other user) + month filter -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,2,8,4">
      <TextBlock Text="User:" VerticalAlignment="Center" Margin="0,0,6,0"/>
      <ComboBox Width="200" ItemsSource="{Binding Targets}" SelectedItem="{Binding SelectedTarget}"
                DisplayMemberPath="Display"/>
      <TextBlock Text="Month:" VerticalAlignment="Center" Margin="16,0,6,0"/>
      <DatePicker SelectedDate="{Binding SelectedMonth, Converter={StaticResource DateOnly}}"
                  ToolTip="Show only tickets in the selected month (pick any day in the month)"/>
      <Border Background="{StaticResource AmberBg}" CornerRadius="7" Padding="10,3" Margin="16,0,0,0"
              VerticalAlignment="Center"
              Visibility="{Binding IsReadOnly, Converter={StaticResource BoolToVisibleConverter}}">
        <TextBlock Text="Read-only (whole team)" FontSize="12" FontWeight="SemiBold"
                   Foreground="{StaticResource AmberFg}"/>
      </Border>
    </StackPanel>

    <!-- Per-column footer totals strip across ALL groups (TS-05, TS-06) -->
    <Grid DockPanel.Dock="Bottom" Margin="8,4,8,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2*"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <TextBlock Grid.Column="0" Text="Day totals" FontWeight="Bold" VerticalAlignment="Center"/>

      <TextBlock Grid.Column="1"
                 Text="{Binding MonTotal, StringFormat=N1}"
                 Tag="{Binding MonTotal, Converter={StaticResource OverEightTag}}"
                 Style="{StaticResource TotalTextBlock}"/>

      <TextBlock Grid.Column="2"
                 Text="{Binding TueTotal, StringFormat=N1}"
                 Tag="{Binding TueTotal, Converter={StaticResource OverEightTag}}"
                 Style="{StaticResource TotalTextBlock}"/>

      <TextBlock Grid.Column="3"
                 Text="{Binding WedTotal, StringFormat=N1}"
                 Tag="{Binding WedTotal, Converter={StaticResource OverEightTag}}"
                 Style="{StaticResource TotalTextBlock}"/>

      <TextBlock Grid.Column="4"
                 Text="{Binding ThuTotal, StringFormat=N1}"
                 Tag="{Binding ThuTotal, Converter={StaticResource OverEightTag}}"
                 Style="{StaticResource TotalTextBlock}"/>

      <TextBlock Grid.Column="5"
                 Text="{Binding FriTotal, StringFormat=N1}"
                 Tag="{Binding FriTotal, Converter={StaticResource OverEightTag}}"
                 Style="{StaticResource TotalTextBlock}"/>

      <TextBlock Grid.Column="6"/>
    </Grid>

    <!-- Column-header strip so the per-group DataGrids (headers hidden) stay aligned -->
    <Grid DockPanel.Dock="Top" Margin="8,4,8,2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2*"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Text="Task" FontWeight="Bold"/>
      <TextBlock Grid.Column="1" Text="{Binding MonHeader}" FontWeight="Bold" HorizontalAlignment="Center"/>
      <TextBlock Grid.Column="2" Text="{Binding TueHeader}" FontWeight="Bold" HorizontalAlignment="Center"/>
      <TextBlock Grid.Column="3" Text="{Binding WedHeader}" FontWeight="Bold" HorizontalAlignment="Center"/>
      <TextBlock Grid.Column="4" Text="{Binding ThuHeader}" FontWeight="Bold" HorizontalAlignment="Center"/>
      <TextBlock Grid.Column="5" Text="{Binding FriHeader}" FontWeight="Bold" HorizontalAlignment="Center"/>
      <TextBlock Grid.Column="6" Text="Total" FontWeight="Bold" HorizontalAlignment="Center"/>
    </Grid>

    <!-- Grouped-by-request body: one collapsible Expander per request (incl. empty ones) -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8,0">
      <ItemsControl ItemsSource="{Binding Groups}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Expander IsExpanded="{Binding IsExpanded}" Margin="0,2">
              <Expander.Header>
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="{Binding Header}" FontWeight="Bold"/>
                  <Border Background="{StaticResource HeaderBg}" CornerRadius="9" Padding="8,1"
                          Margin="12,0,0,0">
                    <TextBlock Text="{Binding GroupTotal, StringFormat='{}{0:N1}h'}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondary}"/>
                  </Border>
                  <!-- v2: status + month badges -->
                  <Border Background="{StaticResource AccentSoft}" CornerRadius="9" Padding="8,1"
                          Margin="8,0,0,0"
                          Visibility="{Binding Status, Converter={StaticResource NullToCollapsedConverter}}">
                    <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource Accent}"/>
                  </Border>
                  <TextBlock Text="{Binding PeriodMonth}" FontSize="12" Margin="8,0,0,0"
                             VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                  <!-- v2: move this ticket to the next month (audited) -->
                  <Button Content="Move &#9654;" FontSize="12" Padding="8,2" Margin="10,0,0,0"
                          Style="{StaticResource MiniGhostButton}"
                          Visibility="{Binding CanMoveMonth, Converter={StaticResource BoolToVisibleConverter}}"
                          IsEnabled="{Binding DataContext.CanEdit, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                          Command="{Binding DataContext.MoveMonthCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                          CommandParameter="{Binding RequestId}"
                          ToolTip="Move ticket to the next month"/>
                </StackPanel>
              </Expander.Header>

              <StackPanel Margin="16,2,0,8">
                <!-- Editable task rows for this request (headers hidden; the strip above labels them) -->
                <DataGrid ItemsSource="{Binding Tasks}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="None"
                          SelectionUnit="Cell"
                          IsReadOnly="{Binding DataContext.IsReadOnly,
                                       RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Task"
                                        Binding="{Binding TaskName}"
                                        IsReadOnly="True"
                                        Width="2*"/>

                    <DataGridTextColumn Width="*"
                        Binding="{Binding Mon,
                                  UpdateSourceTrigger=LostFocus,
                                  TargetNullValue='',
                                  ValidatesOnNotifyDataErrors=True,
                                  NotifyOnValidationError=True}"/>

                    <DataGridTextColumn Width="*"
                        Binding="{Binding Tue,
                                  UpdateSourceTrigger=LostFocus,
                                  TargetNullValue='',
                                  ValidatesOnNotifyDataErrors=True,
                                  NotifyOnValidationError=True}"/>

                    <DataGridTextColumn Width="*"
                        Binding="{Binding Wed,
                                  UpdateSourceTrigger=LostFocus,
                                  TargetNullValue='',
                                  ValidatesOnNotifyDataErrors=True,
                                  NotifyOnValidationError=True}"/>

                    <DataGridTextColumn Width="*"
                        Binding="{Binding Thu,
                                  UpdateSourceTrigger=LostFocus,
                                  TargetNullValue='',
                                  ValidatesOnNotifyDataErrors=True,
                                  NotifyOnValidationError=True}"/>

                    <DataGridTextColumn Width="*"
                        Binding="{Binding Fri,
                                  UpdateSourceTrigger=LostFocus,
                                  TargetNullValue='',
                                  ValidatesOnNotifyDataErrors=True,
                                  NotifyOnValidationError=True}"/>

                    <DataGridTextColumn Header="Total"
                                        Binding="{Binding RowTotal, StringFormat=N1}"
                                        IsReadOnly="True"
                                        Width="*"/>
                  </DataGrid.Columns>
                </DataGrid>

                <!-- Inline add-task row: turns an empty request into a loggable one without leaving the tab -->
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                            IsEnabled="{Binding DataContext.CanEdit,
                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                  <TextBox Width="220"
                           Text="{Binding NewTaskName, UpdateSourceTrigger=PropertyChanged}"
                           VerticalContentAlignment="Center"
                           ToolTip="New task name for this request"/>
                  <Button Content="&#10133; Add task"
                          Command="{Binding AddTaskCommand}"
                          Style="{StaticResource ToolbarGhostButton}"
                          Margin="8,0,0,0"/>
                </StackPanel>
              </StackPanel>
            </Expander>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

  </DockPanel>
</UserControl>
