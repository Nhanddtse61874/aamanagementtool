<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ============================================================
       DARK palette (P19). SAME keys as Palette.Light.xaml.
       Slate-based dark surfaces + a brighter teal accent. Tuned for
       contrast in W3. Swapped in at runtime by ThemeService.
       ============================================================ -->

  <!-- accent (teal, brightened for dark backgrounds) -->
  <Color x:Key="AccentColor">#14B8A6</Color>
  <SolidColorBrush x:Key="Accent" Color="#14B8A6"/>
  <SolidColorBrush x:Key="AccentHover" Color="#2DD4BF"/>
  <SolidColorBrush x:Key="AccentPressed" Color="#0D9488"/>
  <SolidColorBrush x:Key="AccentSoft" Color="#134E4A"/>

  <!-- surfaces / borders / text -->
  <SolidColorBrush x:Key="WindowBg" Color="#0F172A"/>
  <SolidColorBrush x:Key="Surface" Color="#1E293B"/>
  <SolidColorBrush x:Key="Border" Color="#334155"/>
  <SolidColorBrush x:Key="BorderStrong" Color="#475569"/>
  <SolidColorBrush x:Key="MiniGhostBorder" Color="#3E4C63"/>
  <SolidColorBrush x:Key="TextPrimary" Color="#E2E8F0"/>
  <SolidColorBrush x:Key="TextSecondary" Color="#94A3B8"/>
  <SolidColorBrush x:Key="HeaderBg" Color="#172033"/>
  <SolidColorBrush x:Key="GhostText" Color="#CBD5E1"/>

  <!-- status -->
  <SolidColorBrush x:Key="Danger" Color="#F87171"/>
  <SolidColorBrush x:Key="DangerSoft" Color="#7F1D1D"/>
  <SolidColorBrush x:Key="DangerBorder" Color="#991B1B"/>
  <SolidColorBrush x:Key="Disabled" Color="#64748B"/>
  <SolidColorBrush x:Key="HolidayBg" Color="#334155"/>

  <!-- shell: sidebar / tables / stat cards -->
  <SolidColorBrush x:Key="SidebarBg" Color="#0B1220"/>
  <SolidColorBrush x:Key="SidebarBorder" Color="#334155"/>
  <SolidColorBrush x:Key="NavText" Color="#CBD5E1"/>
  <SolidColorBrush x:Key="NavHover" Color="#1E293B"/>
  <SolidColorBrush x:Key="SectionLabel" Color="#64748B"/>
  <SolidColorBrush x:Key="TableHeaderBg" Color="#172033"/>
  <SolidColorBrush x:Key="TableHeaderText" Color="#94A3B8"/>
  <SolidColorBrush x:Key="GroupHeaderBg" Color="#1E293B"/>
  <SolidColorBrush x:Key="StatCardBg" Color="#1E293B"/>

  <!-- badges / amber / resolved -->
  <SolidColorBrush x:Key="BadgeGreenBg" Color="#14532D"/>
  <SolidColorBrush x:Key="BadgeGreenFg" Color="#86EFAC"/>
  <SolidColorBrush x:Key="BadgeGrayBg" Color="#334155"/>
  <SolidColorBrush x:Key="BadgeGrayFg" Color="#CBD5E1"/>
  <SolidColorBrush x:Key="AmberBg" Color="#422006"/>
  <SolidColorBrush x:Key="AmberBorder" Color="#854D0E"/>
  <SolidColorBrush x:Key="AmberFg" Color="#FCD34D"/>
  <SolidColorBrush x:Key="ResolvedBorder" Color="#166534"/>

  <!-- P19 promoted-from-literal keys -->
  <SolidColorBrush x:Key="AltRowBg" Color="#172033"/>
  <SolidColorBrush x:Key="DangerPressed" Color="#DC2626"/>
  <SolidColorBrush x:Key="TrackBg" Color="#334155"/>
</ResourceDictionary>
